model Film {
  id                  Int       @id @default(autoincrement())
  name                String
  brand_id            Int
  film_type           FilmType  @default(FEATURE)
  montage_preset_id   Int?
  target_duration_min Int?      // seconds
  target_duration_max Int?      // seconds
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  brand                 brands                    @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  montage_preset        MontagePreset?            @relation(fields: [montage_preset_id], references: [id], onDelete: SetNull)
  tracks                FilmTimelineTrack[]
  subjects              FilmSubject[]
  locations             FilmLocation[]
  scenes                FilmScene[]
  equipment_assignments FilmEquipmentAssignment[]
  scene_schedules       FilmSceneSchedule[]
  package_films         PackageFilm[]
  project_films         ProjectFilm[]

  @@index([brand_id])
  @@index([montage_preset_id])
  @@map("films")
}

// Film Equipment Assignments (linking Film to Equipment Library)
model FilmEquipmentAssignment {
  id           Int      @id @default(autoincrement())
  film_id      Int
  equipment_id Int
  quantity     Int      @default(1)
  notes        String?
  assigned_at  DateTime @default(now())

  film      Film      @relation(fields: [film_id], references: [id], onDelete: Cascade)
  equipment equipment @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  project_instances ProjectFilmEquipmentAssignment[]

  @@unique([film_id, equipment_id])
  @@index([film_id])
  @@index([equipment_id])
  @@map("film_equipment_assignments")
}

model EquipmentTemplate {
  id           Int      @id @default(autoincrement())
  brand_id     Int
  name         String
  description  String?
  camera_count Int      @default(1)
  audio_count  Int      @default(1)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  brand brands                  @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  items EquipmentTemplateItem[]

  @@index([brand_id])
  @@map("equipment_templates")
}

model EquipmentTemplateItem {
  id           Int                       @id @default(autoincrement())
  template_id  Int
  equipment_id Int
  slot_type    EquipmentTemplateSlotType
  slot_index   Int
  track_name   String? // e.g., "Camera 1", "Camera 2", "Audio 1"
  operator     String? // Operator name (set in projects, not here)
  created_at   DateTime                  @default(now())
  updated_at   DateTime                  @updatedAt

  template  EquipmentTemplate @relation(fields: [template_id], references: [id], onDelete: Cascade)
  equipment equipment         @relation(fields: [equipment_id], references: [id], onDelete: Cascade)

  @@unique([template_id, slot_type, slot_index])
  @@index([template_id])
  @@index([equipment_id])
  @@map("equipment_template_items")
}

model FilmTimelineTrack {
  id             Int       @id @default(autoincrement())
  film_id        Int
  name           String
  type           TrackType
  order_index    Int
  is_active      Boolean   @default(true)
  is_unmanned    Boolean   @default(false) // Static camera — operator responsible but not stationed
  crew_id Int? // Which crew record owns this track
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  film                     Film                      @relation(fields: [film_id], references: [id], onDelete: Cascade)
  crew              Crew?             @relation(fields: [crew_id], references: [id], onDelete: SetNull)
  camera_assignments       CameraSubjectAssignment[]
  scene_camera_assignments SceneCameraAssignment[]
  project_instances        ProjectFilmTimelineTrack[]

  @@unique([film_id, name])
  @@index([film_id])
  @@index([type])
  @@index([crew_id])
  @@map("film_timeline_tracks_v2")
}

model SubjectTemplate {
  id         Int     @id @default(autoincrement())
  brand_id   Int?
  name       String
  is_system  Boolean @default(true)
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt

  brand            brands?                      @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  suggested_scenes SceneTemplateSuggestedSubject[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@map("subject_templates")
}

// Brand-specific subject type templates (e.g., "Wedding" template with roles like "Bride", "Groom")
// Individual role definitions within a subject type template (e.g., "Bride", "Groom" for "Wedding")
model SubjectRole {
  id          Int      @id @default(autoincrement())
  brand_id    Int
  role_name   String // e.g., "Bride", "Groom", "Best Man"
  description String?
  is_core     Boolean  @default(false) // Core roles are pre-selected by default
  is_group    Boolean  @default(false) // Group roles always show a headcount input (e.g., Guests, Bridesmaids)
  never_group Boolean  @default(false) // Never allow group toggle (e.g., Bride, Groom, Maid of Honor)
  order_index Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  brand                  brands                 @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  film_subjects          FilmSubject[]
  package_day_subjects   PackageDaySubject[]
  project_day_subjects   ProjectDaySubject[]
  project_film_subjects  ProjectFilmSubject[]
  event_day_subject_roles EventDaySubjectRole[]
  event_type_subjects    EventTypeSubject[]
  event_subtype_subjects EventSubtypeSubject[]

  @@unique([brand_id, role_name])
  @@index([brand_id])
  @@map("subject_roles")
