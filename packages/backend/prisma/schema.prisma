  last_activity DateTime            @default(now())
  is_active     Boolean             @default(true)
  change_logs   TimelineChangeLog[]
  film          filmLibrary         @relation(fields: [film_id], references: [id], onDelete: Cascade)
  user          contributors        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([film_id, user_id, session_start])
  @@map("timeline_editing_sessions")
}

model TimelineChangeLog {
  id            Int                     @id @default(autoincrement())
  film_id       Int
  scene_id      Int?
  change_type   String
  old_values    Json?
  new_values    Json?
  changed_by_id Int
  changed_at    DateTime                @default(now())
  session_id    Int?
  changed_by    contributors            @relation(fields: [changed_by_id], references: [id])
  film          filmLibrary             @relation(fields: [film_id], references: [id], onDelete: Cascade)
  scene         ScenesLibrary?          @relation(fields: [scene_id], references: [id])
  session       TimelineEditingSession? @relation(fields: [session_id], references: [id])

  @@map("timeline_change_log")
}

model workflow_templates {
  id             Int               @id @default(autoincrement())
  name           String            @unique
  description    String?
  is_active      Boolean           @default(true)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  coverage       coverage[]
  editing_styles editing_styles[]
  filmLibrary    filmLibrary[]
  projects       projects[]
  scenes         ScenesLibrary[]
  stages         workflow_stages[]

  @@map("workflow_templates")
}

model workflow_stages {
  id                    Int                     @id @default(autoincrement())
  workflow_template_id  Int
  name                  String
  description           String?
  order_index           Int
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt
  task_generation_rules task_generation_rules[]
  workflow_template     workflow_templates      @relation(fields: [workflow_template_id], references: [id], onDelete: Cascade)

  @@unique([workflow_template_id, order_index])
  @@map("workflow_stages")
}

model task_generation_rules {
  id                  Int             @id @default(autoincrement())
  workflow_stage_id   Int
  task_template_id    Int
  scene_type          MediaType?
  coverage_id         Int?
  is_required         Boolean         @default(true)
  auto_assign_to_role String?
  conditions          Json?
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  coverage            coverage?       @relation(fields: [coverage_id], references: [id])
  task_template       task_templates  @relation(fields: [task_template_id], references: [id], onDelete: Cascade)
  workflow_stage      workflow_stages @relation(fields: [workflow_stage_id], references: [id], onDelete: Cascade)

  @@map("task_generation_rules")
}

model generated_task_log {
  id                      Int      @id @default(autoincrement())
  project_id              Int
  task_generation_rule_id Int
  task_id                 Int
  generated_at            DateTime @default(now())
  project                 projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  task                    tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@map("generated_task_log")
}

model entity_default_tasks {
  id               Int             @id @default(autoincrement())
  entity_type      String
  entity_id        Int
  task_template_id Int?
  task_name        String
  estimated_hours  Decimal         @default(0) @db.Decimal(4, 2)
  order_index      Int
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  task_template    task_templates? @relation(fields: [task_template_id], references: [id])

  @@unique([entity_type, entity_id, order_index])
  @@index([entity_type, entity_id])
  @@map("entity_default_tasks")
}

model task_library {
  id                       Int                        @id @default(autoincrement())
  name                     String
  description              String?
  phase                    project_phase
  effort_hours             Decimal?                   @db.Decimal(8, 2)
  recorded_hours           Decimal?                   @db.Decimal(8, 2)
  skills_needed            String[]
  pricing_type             pricing_type_options       @default(Hourly)
  fixed_price              Decimal?                   @db.Decimal(10, 2)
  hourly_rate              Decimal?                   @db.Decimal(8, 2)
  complexity_score         Int?                       @default(1)
  notes                    String?
  order_index              Int                        @default(0)
  brand_id                 Int
  is_active                Boolean                    @default(true)
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @updatedAt
  brand                    brands                     @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  task_library_benchmarks  task_library_benchmarks[]
  task_library_skill_rates task_library_skill_rates[]

  @@index([brand_id])
  @@index([phase])
  @@index([is_active])
  @@index([phase, order_index])
  @@map("task_library")
}

model task_library_benchmarks {
  id                        Int          @id @default(autoincrement())
  task_library_id           Int
  contributor_id            Int
  contributor_default_hours Decimal?     @db.Decimal(8, 2)
  contributor_average_hours Decimal?     @db.Decimal(8, 2)
  contributor_best_hours    Decimal?     @db.Decimal(8, 2)
  completed_count           Int          @default(0)
  created_at                DateTime     @default(now())
  updated_at                DateTime     @updatedAt
  contributor               contributors @relation(fields: [contributor_id], references: [id], onDelete: Cascade)
  task_library              task_library @relation(fields: [task_library_id], references: [id], onDelete: Cascade)

  @@unique([task_library_id, contributor_id])
  @@map("task_library_benchmarks")
}

model task_library_skill_rates {
  id              Int          @id @default(autoincrement())
  task_library_id Int
  skill_name      String
  skill_level     String
  hourly_rate     Decimal      @db.Decimal(8, 2)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  task_library    task_library @relation(fields: [task_library_id], references: [id], onDelete: Cascade)

  @@unique([task_library_id, skill_name, skill_level])
  @@map("task_library_skill_rates")
}

model SceneMediaComponent {
  id                Int                            @id @default(autoincrement())
  scene_id          Int
  media_type        MediaType
  duration_seconds  Int
  is_primary        Boolean                        @default(false)
  music_type        String?
  notes             String?
  created_at        DateTime                       @default(now())
  updated_at        DateTime                       @updatedAt
  film_local_copies FilmLocalSceneMediaComponent[] @relation("FilmLocalToOriginalComponent")
  scene             ScenesLibrary                  @relation(fields: [scene_id], references: [id], onDelete: Cascade)

  @@index([scene_id])
  @@index([media_type])
  @@index([music_type])
  @@map("scene_media_components")
}

model equipment {
  id                   Int                      @id @default(autoincrement())
  item_name            String
  item_code            String?
  category             EquipmentCategory
  type                 EquipmentType
  brand_name           String?
  model                String?
  description          String?
  quantity             Int                      @default(1)
  condition            EquipmentCondition       @default(GOOD)
  availability_status  EquipmentAvailability    @default(AVAILABLE)
  vendor               String?
  rental_price_per_day Decimal?                 @db.Decimal(10, 2)
  purchase_price       Decimal?                 @db.Decimal(10, 2)
  purchase_date        DateTime?
  weight_kg            Decimal?                 @db.Decimal(8, 2)
  power_usage_watts    Int?
  dimensions           String?
  specifications       Json?
  attachment_type      String?
  compatibility        String?
  serial_number        String?
  warranty_expiry      DateTime?
  last_maintenance     DateTime?
  next_maintenance_due DateTime?
  location             String?
  brand_id             Int?
  is_active            Boolean                  @default(true)
  created_at           DateTime                 @default(now())
  updated_at           DateTime                 @updatedAt
  created_by_id        Int?
  brand                brands?                  @relation(fields: [brand_id], references: [id])
  created_by           contributors?            @relation("EquipmentCreatedBy", fields: [created_by_id], references: [id])
  availability_slots   equipment_availability[]
  maintenance_logs     equipment_maintenance[]
  rental_bookings      equipment_rentals[]

  @@index([brand_id])
  @@index([category])
  @@index([type])
  @@index([availability_status])
  @@index([item_code])
  @@map("equipment")
}

model equipment_rentals {
  id                 Int                     @id @default(autoincrement())
  equipment_id       Int
  project_id         Int?
  rented_by_id       Int?
  client_id          Int?
  rental_start_date  DateTime
  rental_end_date    DateTime
  actual_return_date DateTime?
  rental_rate        Decimal                 @db.Decimal(10, 2)
  total_cost         Decimal                 @db.Decimal(10, 2)
  deposit_amount     Decimal?                @db.Decimal(10, 2)
  status             equipment_rental_status @default(BOOKED)
  notes              String?
  created_at         DateTime                @default(now())
  updated_at         DateTime                @updatedAt
  client             clients?                @relation(fields: [client_id], references: [id])
  equipment          equipment               @relation(fields: [equipment_id], references: [id])
  project            projects?               @relation(fields: [project_id], references: [id])
  rented_by          contributors?           @relation(fields: [rented_by_id], references: [id])

  @@index([equipment_id])
  @@index([project_id])
  @@index([rental_start_date])
  @@index([status])
  @@map("equipment_rentals")
}

model equipment_maintenance {
  id               Int                        @id @default(autoincrement())
  equipment_id     Int
  maintenance_type equipment_maintenance_type
  description      String
  cost             Decimal?                   @db.Decimal(10, 2)
  performed_by     String?
  performed_date   DateTime
  next_due_date    DateTime?
  notes            String?
  created_at       DateTime                   @default(now())
  created_by_id    Int?
  created_by       contributors?              @relation(fields: [created_by_id], references: [id])
  equipment        equipment                  @relation(fields: [equipment_id], references: [id])

  @@index([equipment_id])
  @@index([maintenance_type])
  @@index([performed_date])
  @@map("equipment_maintenance")
}

model equipment_availability {
  id              Int                           @id @default(autoincrement())
  equipment_id    Int
  start_date      DateTime
  end_date        DateTime
  all_day         Boolean                       @default(true)
  status          equipment_availability_status @default(AVAILABLE)
  title           String?
  description     String?
  project_id      Int?
  booked_by_id    Int?
  client_id       Int?
  booking_notes   String?
  internal_notes  String?
  recurring_rule  String?
  recurring_until DateTime?
  created_at      DateTime                      @default(now())
  updated_at      DateTime                      @updatedAt
  created_by_id   Int?
  booked_by       contributors?                 @relation("EquipmentBookedBy", fields: [booked_by_id], references: [id])
  client          clients?                      @relation(fields: [client_id], references: [id])
  created_by      contributors?                 @relation("EquipmentAvailabilityCreatedBy", fields: [created_by_id], references: [id])
  equipment       equipment                     @relation(fields: [equipment_id], references: [id], onDelete: Cascade)
  project         projects?                     @relation(fields: [project_id], references: [id])

  @@index([equipment_id])
  @@index([start_date])
  @@index([end_date])
  @@index([status], map: "equipment_availability_slots_status_idx")
  @@index([project_id])
  @@map("equipment_availability")
}

model LocationsLibrary {
  id                          Int                  @id @default(autoincrement())
  name                        String
  address_line1               String?
  address_line2               String?
  city                        String?
  state                       String?
  country                     String               @default("United States")
  postal_code                 String?
  contact_name                String?
  contact_phone               String?
  contact_email               String?
  capacity                    Int?
  notes                       String?
  brand_id                    Int?
  is_active                   Boolean              @default(true)
  created_at                  DateTime             @default(now())
  updated_at                  DateTime             @updatedAt
  venue_floor_plan_data       Json?
  venue_floor_plan_updated_at DateTime?
  venue_floor_plan_updated_by Int?
  venue_floor_plan_version    Int                  @default(1)
  spaces                      LocationSpaces[]
  brand                       brands?              @relation(fields: [brand_id], references: [id])
  venue_floor_plan_updater    contributors?        @relation("VenueFloorPlanUpdater", fields: [venue_floor_plan_updated_by], references: [id])
  scene_locations             SceneLocationSpace[]

  @@index([brand_id])
  @@map("locations_library")
}

model LocationSpaces {
  id                Int                  @id @default(autoincrement())
  location_id       Int
  name              String
  space_type        String
  capacity          Int?
  dimensions_length Decimal?             @db.Decimal(8, 2)
  dimensions_width  Decimal?             @db.Decimal(8, 2)
  dimensions_height Decimal?             @db.Decimal(8, 2)
  metadata          Json?
  notes             String?
  is_active         Boolean              @default(true)
  created_at        DateTime             @default(now())
  updated_at        DateTime             @updatedAt
  floor_plans       FloorPlans[]
  location          LocationsLibrary     @relation(fields: [location_id], references: [id], onDelete: Cascade)
  scene_locations   SceneLocationSpace[]

  @@index([location_id])
  @@map("location_spaces")
}

model FloorPlans {
  id            Int            @id @default(autoincrement())
  space_id      Int
  project_id    Int?
  name          String
  version       Int            @default(1)
  fabric_data   Json
  layers_data   Json?
  is_default    Boolean        @default(false)
  is_active     Boolean        @default(true)
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  created_by_id Int?
  created_by    contributors?  @relation("FloorPlanCreatedBy", fields: [created_by_id], references: [id])
  project       projects?      @relation(fields: [project_id], references: [id], onDelete: Cascade)
  space         LocationSpaces @relation(fields: [space_id], references: [id], onDelete: Cascade)

  @@unique([space_id, project_id, version])
  @@index([space_id])
  @@index([project_id])
  @@map("floor_plans")
}

model FloorPlanObjects {
  id              Int      @id @default(autoincrement())
  name            String
  category        String
  object_type     String
  fabric_template Json
  thumbnail_url   String?
  brand_id        Int?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  brand           brands?  @relation(fields: [brand_id], references: [id])

  @@index([brand_id])
  @@index([category])
  @@map("floor_plan_objects")
}

model SceneLocationSpace {
  id          Int              @id @default(autoincrement())
  scene_id    Int              @unique
  location_id Int
  space_id    Int
  created_at  DateTime         @default(now())
  updated_at  DateTime         @updatedAt
  location    LocationsLibrary @relation(fields: [location_id], references: [id], onDelete: Cascade)
  scene       ScenesLibrary    @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  space       LocationSpaces   @relation(fields: [space_id], references: [id], onDelete: Cascade)

  @@index([location_id])
  @@index([space_id])
  @@map("scene_location_space")
}

