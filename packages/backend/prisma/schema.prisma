  @@index([film_structure_template_id])
  @@map("film_structure_template_scenes")
}

// ─── Scene Audio Sources (audio layering — e.g. vows over montage) ───
model SceneAudioSource {
  id                   Int             @id @default(autoincrement())
  scene_id             Int             // The montage scene using this audio
  source_type          AudioSourceType
  source_activity_id   Int?            // e.g., Ceremony activity
  source_moment_id     Int?            // e.g., Vows moment
  source_scene_id      Int?            // e.g., a realtime scene in another film
  track_type           AudioTrackType  @default(SPEECH)
  start_offset_seconds Int?            // Where in the source to start pulling
  duration_seconds     Int?            // How much to use
  order_index          Int             @default(0) // Layering order
  notes                String?         // Editor notes ("use emotional part of vows")
  created_at           DateTime        @default(now())
  updated_at           DateTime        @updatedAt

  scene           FilmScene              @relation("SceneAudioSources", fields: [scene_id], references: [id], onDelete: Cascade)
  source_activity PackageActivity?       @relation(fields: [source_activity_id], references: [id], onDelete: SetNull)
  source_moment   PackageActivityMoment? @relation("AudioSourceMoment", fields: [source_moment_id], references: [id], onDelete: SetNull)
  source_scene    FilmScene?             @relation("AudioSourceScene", fields: [source_scene_id], references: [id], onDelete: SetNull)

  @@index([scene_id])
  @@index([source_activity_id])
  @@index([source_moment_id])
  @@index([source_scene_id])
  @@map("scene_audio_sources")
}

