// ─── Film Structure Templates (scene layout blueprints, brand-scoped) ───
model FilmStructureTemplate {
  id               Int      @id @default(autoincrement())
  brand_id         Int?     // null = system-seeded global default
  name             String   // "Classic 4-Scene", "Emotional Arc", "Music-Driven 3-Act"
  description      String?
  film_type        FilmType @default(MONTAGE) // which film type this template applies to
  is_system_seeded Boolean  @default(false)
  is_active        Boolean  @default(true)
