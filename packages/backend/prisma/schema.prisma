generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider   = "prisma-dbml-generator"
  output     = "../docs"
  outputName = "schema.dbml"
  projectName = "ProjectFlo"
  projectDatabaseType = "PostgreSQL"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model brands {
  id                           Int                            @id @default(autoincrement())
  name                         String                         @unique
  display_name                 String?
  description                  String?
  business_type                String?
  website                      String?
  email                        String?
  phone                        String?
  address_line1                String?
  address_line2                String?
  city                         String?
  state                        String?
  country                      String                         @default("United States")
  postal_code                  String?
  timezone                     String                         @default("America/New_York")
  currency                     String                         @default("USD")
  logo_url                     String?
  // Payment & tax defaults
  default_tax_rate             Decimal?                       @default(0) @db.Decimal(5, 2)
  tax_number                   String?
  default_payment_method       String?                        @default("Bank Transfer")
  payment_terms_days           Int?                           @default(30)
  bank_name                    String?
  bank_account_name            String?
  bank_sort_code               String?
  bank_account_number          String?
  // Crew engagement defaults
  crew_payment_terms           String?                        @default("50% on booking confirmation, 50% within 7 days of delivery")
  crew_response_deadline_days  Int?                           @default(5)
  // Services offered (auto-provisioning)
  service_types                String[]                       @default([])
  // Inquiry defaults
  inquiry_validity_days        Int?                           @default(14)
  // Contract policy defaults
  late_fee_percent             Decimal?                       @default(2) @db.Decimal(5, 2)
  cancellation_tier1_days      Int?                           @default(90)
  cancellation_tier2_days      Int?                           @default(30)
  cancellation_tier1_percent   Decimal?                       @default(50) @db.Decimal(5, 2)
  is_active                    Boolean                        @default(true)
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime                       @updatedAt
  brand_settings               brand_settings[]
  contacts                     contacts[]
  equipment                    equipment[]
  filmLibrary                  filmLibrary[]
  locations                    LocationsLibrary[]
  projects                     projects[]
    system_roles                 SystemRole[]
  task_library                 task_library[]
    brand_members                BrandMember[]
  service_packages             service_packages[]
  service_package_categories   service_package_categories[]
  films                        Film[]
  montage_presets              MontagePreset[]
  film_structure_templates     FilmStructureTemplate[]
  inquiry_wizard_templates          inquiry_wizard_templates[]
  inquiry_wizard_submissions         inquiry_wizard_submissions[]
  discovery_questionnaire_templates    discovery_questionnaire_templates[]
  discovery_questionnaire_submissions  discovery_questionnaire_submissions[]
  subject_roles                SubjectRole[]
  equipment_templates          EquipmentTemplate[]
  event_days          EventDay[]
  schedule_presets             SchedulePreset[]
  event_subtypes                EventSubtype[]
  event_types                  EventType[]
  workflow_templates           workflow_templates[]
  package_sets                 package_sets[]
  skill_role_mappings          skill_role_mappings[]
  payment_schedule_templates   payment_schedule_templates[]
  crew_payment_templates        crew_payment_templates[]
  subject_templates            SubjectTemplate[]
  scene_templates              SceneTemplate[]
  contract_clause_categories    contract_clause_categories[]
  contract_clauses              contract_clauses[]
  contract_templates            contract_templates[]
  finance_settings              brand_finance_settings?

  @@map("brands")
}

model brand_settings {
  id          Int      @id @default(autoincrement())
  brand_id    Int
  key         String
  value       String
  data_type   String   @default("string")
  category    String?
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  brand       brands   @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@unique([brand_id, key])
  @@index([brand_id])
  @@index([category])
  @@map("brand_settings")
}

model brand_finance_settings {
  id                        Int      @id @default(autoincrement())
  brand_id                  Int      @unique
  onsite_half_day_max_hours Int      @default(6)  // Hours below which on-site work is billed at half_day_rate
  onsite_full_day_max_hours Int      @default(12) // Hours at/above which overtime kicks in
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  brand brands @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@map("brand_finance_settings")
}

model BrandMember {
  id        Int          @id @default(autoincrement())
  crew_id Int
  brand_id  Int
  is_active Boolean      @default(true)
  joined_at DateTime     @default(now())
  brand       brands     @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  crew Crew @relation(fields: [crew_id], references: [id], onDelete: Cascade)

  @@unique([crew_id, brand_id])
  @@index([crew_id])
  @@index([brand_id])
  @@map("brand_members")
}

model contacts {
  id                           Int                            @id @default(autoincrement())
  first_name                   String?
  last_name                    String?
  email                        String                         @unique
  phone_number                 String?
  company_name                 String?
  type                         contacts_type
  brand_id                     Int?
  archived_at                  DateTime?
  activities                   activities[]
  client                       clients?
  communications_log           communications_log[]
  brand                        brands?                        @relation(fields: [brand_id], references: [id])
  crew                  Crew?
  user_account                 UserAccount?
  event_attendees              event_attendees[]
  inquiries                    inquiries[]
  inquiry_wizard_submissions inquiry_wizard_submissions[]
  project_day_subjects         ProjectDaySubject[]

  @@index([email])
  @@index([type])
  @@index([brand_id])
  @@map("contacts")
}

model UserAccount {
  id             Int        @id @default(autoincrement())
  contact_id     Int        @unique
  password_hash  String
  system_role_id Int?
  archived_at    DateTime?
  contact        contacts   @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  system_role    SystemRole? @relation(fields: [system_role_id], references: [id], onDelete: Restrict)

  @@index([system_role_id])
  @@map("user_accounts")
}

model coverage {
  id                         Int                          @id @default(autoincrement())
  name                       String                       @unique
  description                String?
  workflow_template_id       Int?
  recording_equipment        Json?
  aperture                   String?
  audio_equipment            AudioEquipment?
  camera_movement            CameraMovement?
  is_active                  Boolean                      @default(true)
  lens_focal_length          String?
  notes                      String?
  shot_type                  ShotType?
  subject                    String?
  coverage_type              CoverageType?
  audio_pattern              String?
  frequency_response         String?
  equipment_assignments      Json?
  crew_id                Int?
  job_role_id                Int?
  is_template                Boolean                      @default(false)
  video_style_type           VideoStyleType?
  resource_requirements      Json? // Stores generic requirements: [{ category: string, quantity: number }]
  crew                Crew?                      @relation("CoverageCrew", fields: [crew_id], references: [id])
  job_role                   job_roles?                   @relation(fields: [job_role_id], references: [id])
  workflow_template          workflow_templates?          @relation(fields: [workflow_template_id], references: [id])
  project_assets             project_assets[]

  @@map("coverage")
}

model film_categories {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("film_categories")
}

model filmLibrary {
  id                   Int                      @id @default(autoincrement())
  name                 String                   @unique
  description          String?
  workflow_template_id Int?
  brand_id             Int?
  created_at           DateTime                 @default(now())
  default_music_type   MusicType?
  delivery_timeline    Int?
  includes_music       Boolean                  @default(true)
  is_active            Boolean                  @default(true)
  type                 FilmType                 @default(FEATURE)
  updated_at           DateTime                 @updatedAt
  version              String                   @default("1.0")
  change_logs          FilmChangeLog[]
  equipment            FilmEquipment[]
  timeline_tracks      FilmTimelineTracks[]
  brand                brands?                  @relation(fields: [brand_id], references: [id])
  workflow_template    workflow_templates?      @relation(fields: [workflow_template_id], references: [id])
  music_tracks         FilmMusicTrack[]
  versions             FilmVersion[]
  timeline_sessions    TimelineEditingSession[]

  @@index([brand_id])
  @@map("film_library")
}

model editing_styles {
  id                         Int                          @id @default(autoincrement())
  name                       String                       @unique
  description                String?
  workflow_template_id       Int?
  workflow_template          workflow_templates?          @relation(fields: [workflow_template_id], references: [id])

  @@map("editing_styles")
}

// Legacy models removed - see migration 20260131000000_delete_legacy_models

// Legacy models removed

// Legacy moment models removed

model FilmMusicTrack {
  id          Int         @id @default(autoincrement())
  film_id     Int
  music_type  MusicType
  track_name  String?
  artist      String?
  duration    Int?
  order_index Int         @default(0)
  film        filmLibrary @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@map("film_music_tracks")
}

model FilmEquipment {
  id             Int         @id @default(autoincrement())
  film_id        Int
  equipment_type String // 'CAMERA', 'AUDIO', 'MUSIC'
  quantity       Int
  notes          String?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
  film           filmLibrary @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@unique([film_id, equipment_type])
  @@index([film_id])
  @@index([equipment_type])
  @@map("film_equipment")
}

model FilmTimelineTracks {
  id          Int         @id @default(autoincrement())
  film_id     Int
  track_type  MediaType // VIDEO, AUDIO, GRAPHICS, MUSIC
  track_label String? // "Camera 1", "Audio 2"
  order_index Int
  is_active   Boolean     @default(true)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  film        filmLibrary @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@unique([film_id, order_index])
  @@index([film_id])
  @@index([track_type])
  @@map("film_timeline_tracks")
}

// Legacy models removed

model PricingModifier {
  id         Int                 @id @default(autoincrement())
  name       String
  type       PricingModifierType
  multiplier Decimal             @db.Decimal(4, 2)
  is_active  Boolean             @default(true)
  conditions Json?
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt

  @@map("pricing_modifiers")
}

model FilmVersion {
  id               Int          @id @default(autoincrement())
  film_id          Int
  version_number   String
  change_summary   String
  changed_by_id    Int
  created_at       DateTime     @default(now())
  scenes_snapshot  Json
  pricing_snapshot Json
  changed_by       Crew @relation("FilmVersionCreator", fields: [changed_by_id], references: [id])
  film             filmLibrary  @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@map("film_versions")
}

model FilmChangeLog {
  id            Int          @id @default(autoincrement())
  film_id       Int
  change_type   String
  old_value     Json?
  new_value     Json?
  changed_by_id Int
  created_at    DateTime     @default(now())
  changed_by    Crew @relation("FilmChangeUser", fields: [changed_by_id], references: [id])
  film          filmLibrary  @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@map("film_change_logs")
}



model SystemRole {
  id                  Int                   @id @default(autoincrement())
  name                String                @unique
  description         String?
  brand_id            Int?
  user_accounts       UserAccount[]
  role_permissions    role_permissions[]
  brand               brands?               @relation(fields: [brand_id], references: [id])

  @@index([brand_id])
  @@map("system_roles")
}

model permissions {
  id               Int                @id @default(autoincrement())
  action_name      String             @unique
  description      String?
  role_permissions role_permissions[]

  @@map("permissions")
}

model role_permissions {
  role_id       Int
  permission_id Int
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  system_role   SystemRole  @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model inquiries {
  id                           Int                            @id @default(autoincrement())
  contact_id                   Int
  wedding_date                 DateTime?
  status                       inquiries_status               @default(New)
  notes                        String?
  follow_up_due_date           DateTime?
  lead_source                  String?
  lead_source_details          String?
  campaign_id                  String?
  archived_at                  DateTime?
  workflow_status              Json?
  selected_package_id          Int?
  source_package_id            Int? // Which package was cloned into this inquiry's schedule
  package_contents_snapshot    Json? // Frozen copy of package contents at clone time
  guest_count                  String?
  event_type_id                Int?
  portal_token                 String?                        @unique
  selected_package             service_packages?              @relation(fields: [selected_package_id], references: [id])
  source_package_for_inquiry   service_packages?              @relation("InquirySourcePackage", fields: [source_package_id], references: [id], onDelete: SetNull)
  event_type                   EventType?                     @relation(fields: [event_type_id], references: [id])
  activities                   activities[]
  calendar_events              calendar_events[]
  client                       clients?
  contracts                    contracts[]
  documents                    documents[]
  estimates                    estimates[]
  contact                      contacts                       @relation(fields: [contact_id], references: [id])
  invoices                     invoices[]
  proposals                    proposals[]
  quotes                       quotes[]
  inquiry_wizard_submissions         inquiry_wizard_submissions[]
  discovery_questionnaire_submissions  discovery_questionnaire_submissions[]
  inquiry_tasks                        inquiry_tasks[]
  equipment_reservations               inquiry_equipment_reservations[]
  equipment_availability_blocks        equipment_availability[]

  // Schedule snapshot (owned while inquiry, transferred to project on booking)
  schedule_event_days          ProjectEventDay[]
  schedule_activities          ProjectActivity[]
  schedule_films               ProjectFilm[]
  schedule_day_crew_slots     ProjectCrewSlot[]
  schedule_subjects            ProjectDaySubject[]
  schedule_location_slots      ProjectLocationSlot[]
  schedule_activity_moments    ProjectActivityMoment[]
  schedule_film_tracks         ProjectFilmTimelineTrack[]
  schedule_film_subjects       ProjectFilmSubject[]
  schedule_film_locations      ProjectFilmLocation[]
  schedule_film_scenes         ProjectFilmScene[]
  schedule_film_moments        ProjectFilmSceneMoment[]
  schedule_film_beats          ProjectFilmSceneBeat[]
  schedule_film_equipment      ProjectFilmEquipmentAssignment[]
  package_requests             package_requests[]
  preferred_payment_schedule_template_id Int?
  preferred_payment_schedule   payment_schedule_templates?    @relation("InquiryPreferredPaymentSchedule", fields: [preferred_payment_schedule_template_id], references: [id], onDelete: SetNull)
  created_at                   DateTime                       @default(now())
  updated_at                   DateTime                       @default(now()) @updatedAt
  welcome_sent_at              DateTime?

  @@index([source_package_id])
  @@index([preferred_payment_schedule_template_id])
  @@map("inquiries")
}

model inquiry_wizard_templates {
  id           Int                            @id @default(autoincrement())
  brand_id     Int
  name         String
  description  String?
  is_active    Boolean                        @default(true)
  status       String                         @default("draft")
  version      String                         @default("1.0")
  published_at DateTime?
  steps_config Json?
  share_token  String?                        @unique
  created_at   DateTime                       @default(now())
  updated_at   DateTime                       @updatedAt
  brand        brands                         @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  questions    inquiry_wizard_questions[]
  submissions  inquiry_wizard_submissions[]

  @@index([brand_id])
  @@map("needs_assessment_templates")
}

model inquiry_wizard_questions {
  id             Int                       @id @default(autoincrement())
  template_id    Int
  order_index    Int
  prompt         String
  field_type     String
  field_key      String?
  required       Boolean                   @default(false)
  options        Json?
  condition_json Json?
  help_text      String?
  category       String?
  created_at     DateTime                  @default(now())
  updated_at     DateTime                  @updatedAt
  template       inquiry_wizard_templates  @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@map("needs_assessment_questions")
}

model inquiry_wizard_submissions {
  id                      Int                       @id @default(autoincrement())
  template_id             Int
  brand_id                Int
  inquiry_id              Int?
  contact_id              Int?
  status                  String                    @default("submitted")
  responses               Json
  submitted_at            DateTime                  @default(now())
  created_at              DateTime                  @default(now())
  updated_at              DateTime                  @updatedAt
  review_notes            String?
  reviewed_at             DateTime?
  review_checklist_state  Json?
  template                inquiry_wizard_templates  @relation(fields: [template_id], references: [id], onDelete: Cascade)
  brand                   brands                    @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  inquiry                 inquiries?                @relation(fields: [inquiry_id], references: [id])
  contact                 contacts?                 @relation(fields: [contact_id], references: [id])

  @@index([brand_id])
  @@index([inquiry_id])
  @@map("needs_assessment_submissions")
}

// ─── Discovery Questionnaire ─────────────────────────────────────────────────

model discovery_questionnaire_templates {
  id          Int                                      @id @default(autoincrement())
  brand_id    Int
  name        String
  description String?
  is_active   Boolean                                  @default(true)
  created_at  DateTime                                 @default(now())
  updated_at  DateTime                                 @updatedAt
  brand       brands                                   @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  questions   discovery_questionnaire_questions[]
  submissions discovery_questionnaire_submissions[]

  @@index([brand_id])
  @@map("discovery_questionnaire_templates")
}

model discovery_questionnaire_questions {
  id          Int                                    @id @default(autoincrement())
  template_id Int
  order_index Int
  section     String?
  prompt      String
  script_hint String?
  field_type  String
  field_key   String?
  required    Boolean                                @default(false)
  options     Json?
  visibility  String                                 @default("both")
  created_at  DateTime                               @default(now())
  updated_at  DateTime                               @updatedAt
  template    discovery_questionnaire_templates      @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@map("discovery_questionnaire_questions")
}

model discovery_questionnaire_submissions {
  id           Int                                @id @default(autoincrement())
  template_id  Int
  brand_id     Int
  inquiry_id   Int?
  responses    Json
  call_notes   String?
  transcript   String?
  sentiment              Json?
  call_duration_seconds  Int?
  submitted_at           DateTime                           @default(now())
  created_at   DateTime                           @default(now())
  updated_at   DateTime                           @updatedAt
  template     discovery_questionnaire_templates  @relation(fields: [template_id], references: [id], onDelete: Cascade)
  brand        brands                             @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  inquiry      inquiries?                         @relation(fields: [inquiry_id], references: [id])

  @@index([brand_id])
  @@index([inquiry_id])
  @@map("discovery_questionnaire_submissions")
}

model clients {
  id                     Int                      @id @default(autoincrement())
  contact_id             Int                      @unique
  inquiry_id             Int?                     @unique
  archived_at            DateTime?
  client_user            client_users?
  contact                contacts                 @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  inquiry                inquiries?               @relation(fields: [inquiry_id], references: [id])
  equipment_availability equipment_availability[]
  equipment_rentals      equipment_rentals[]
  projects               projects[]

  @@map("clients")
}

model client_users {
  id              Int       @id @default(autoincrement())
  client_id       Int       @unique
  email           String    @unique
  password_hash   String
  last_login_date DateTime?
  client          clients   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@map("client_users")
}

model projects {
  id                         Int                       @id @default(autoincrement())
  client_id                  Int
  workflow_template_id       Int?
  brand_id                   Int?
  source_package_id          Int? // Traceability: which service_package was cloned at conversion
  project_name               String?
  wedding_date               DateTime
  booking_date               DateTime?
  edit_start_date            DateTime?
  delivery_date              DateTime?
  phase                      String?
  package_contents_snapshot   Json? // Frozen copy of service_packages.contents at clone time
  archived_at                DateTime?
  activities                 activities[]
  calendar_events            calendar_events[]
  client_feedback_surveys    client_feedback_surveys[]
  communications_log         communications_log[]
  contracts                  contracts[]
  documents                  documents[]
  equipment_availability     equipment_availability[]
  equipment_rentals          equipment_rentals[]
  estimates                  estimates[]
  invoices                   invoices[]
  project_assets             project_assets[]
  project_expenses           project_expenses[]
  brand                      brands?                   @relation(fields: [brand_id], references: [id])
  client                     clients                   @relation(fields: [client_id], references: [id])
  source_package             service_packages?         @relation("ProjectSourcePackage", fields: [source_package_id], references: [id], onDelete: SetNull)
  workflow_template          workflow_templates?       @relation(fields: [workflow_template_id], references: [id])
  proposals                  proposals[]
  quotes                     quotes[]
  project_tasks              project_tasks[]
  project_event_days         ProjectEventDay[]
  project_films              ProjectFilm[]
  project_activities         ProjectActivity[]
  project_crew_slots         ProjectCrewSlot[]
  project_subjects           ProjectDaySubject[]
  project_location_slots     ProjectLocationSlot[]
  project_activity_moments   ProjectActivityMoment[]
  project_film_tracks        ProjectFilmTimelineTrack[]
  project_film_subjects      ProjectFilmSubject[]
  project_film_locations     ProjectFilmLocation[]
  project_film_scenes        ProjectFilmScene[]
  project_film_moments       ProjectFilmSceneMoment[]
  project_film_beats         ProjectFilmSceneBeat[]
  project_film_equipment     ProjectFilmEquipmentAssignment[]

  @@unique([client_id, wedding_date])
  @@index([wedding_date])
  @@index([brand_id])
  @@index([source_package_id])
  @@map("projects")
}

model Crew {
  id                             Int                           @id @default(autoincrement())
  contact_id                     Int                           @unique
  crew_color                     String? // hex color for UI display
  bio                            String? // short biography
  activities_assigned            activities[]
  audit_logs                     audit_log[]
  calendar_events                calendar_events[]
  calendar_settings              calendar_settings?
  calendar_sync_token            calendar_sync_tokens?
  job_roles_assigned             CrewJobRole[]       @relation("JobRoleAssignedBy")
  job_role_assignments           CrewJobRole[]
  contact                        contacts                      @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  coverage_assignments           coverage[]                    @relation("CoverageCrew")
  equipment_created              equipment[]                   @relation("EquipmentCreatedBy")
  equipment_owned                equipment[]                   @relation("EquipmentOwner")
  equipment_booked               equipment_availability[]      @relation("EquipmentBookedBy")
  equipment_availability_created equipment_availability[]      @relation("EquipmentAvailabilityCreatedBy")
  equipment_maintenance          equipment_maintenance[]
  equipment_rented               equipment_rentals[]
  event_attendees                event_attendees[]
  film_changes_made              FilmChangeLog[]               @relation("FilmChangeUser")
  film_versions_created          FilmVersion[]                 @relation("FilmVersionCreator")
  notifications_received         notifications[]
  package_crew_assignments       PackageCrewSlot[]
  project_crew_assignments       ProjectCrewSlot[]

  task_library_benchmarks        task_library_benchmarks[]
  default_task_library_entries   task_library[]                @relation("TaskLibraryDefaultCrew")
  project_tasks_assigned         project_tasks[]               @relation("AssignedProjectTasks")
  inquiry_tasks_completed        inquiry_tasks[]               @relation("CompletedInquiryTasks")
  inquiry_task_subtasks_completed inquiry_task_subtasks[]      @relation("CompletedInquiryTaskSubtasks")
  inquiry_tasks_assigned         inquiry_tasks[]               @relation("AssignedInquiryTasks")

  timeline_sessions              TimelineEditingSession[]
  timeline_tracks                FilmTimelineTrack[]
  project_film_timeline_tracks   ProjectFilmTimelineTrack[]
  brand_memberships              BrandMember[]

  @@map("crew")
}

model job_roles {
  id                    Int                     @id @default(autoincrement())
  name                  String                  @unique
  description           String?
  display_name          String?
  category              String?
  on_site               Boolean                 @default(false)
  is_active             Boolean                 @default(true)
