  package_activity  PackageActivity @relation(fields: [package_activity_id], references: [id], onDelete: Cascade)

  @@unique([package_crew_slot_id, package_activity_id])
  @@index([package_crew_slot_id])
  @@index([package_activity_id])
  @@map("package_crew_slot_activities")
}

model PackageDaySubjectActivity {
  id                     Int      @id @default(autoincrement())
  package_day_subject_id Int
  package_activity_id    Int
  created_at             DateTime @default(now())

  package_day_subject PackageDaySubject @relation(fields: [package_day_subject_id], references: [id], onDelete: Cascade)
  package_activity    PackageActivity   @relation(fields: [package_activity_id], references: [id], onDelete: Cascade)

  @@unique([package_day_subject_id, package_activity_id])
  @@index([package_day_subject_id])
  @@index([package_activity_id])
  @@map("package_day_subject_activities")
}

// ─── Package Location Slots ─────────────────────────────────────────
// Abstract numbered location slots (1-5) per event day in a package.
// Real locations are assigned in projects, not packages.

model PackageLocationSlot {
  id                    Int      @id @default(autoincrement())
  package_id            Int
  event_day_template_id Int
  location_number       Int // 1-5
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  package              service_packages           @relation(fields: [package_id], references: [id], onDelete: Cascade)
  event_day            EventDay                   @relation(fields: [event_day_template_id], references: [id], onDelete: Cascade)
  activity_assignments LocationActivityAssignment[]

  @@unique([package_id, event_day_template_id, location_number])
  @@index([package_id])
  @@index([event_day_template_id])
  @@map("package_location_slots")
}

model LocationActivityAssignment {
  id                       Int      @id @default(autoincrement())
  package_location_slot_id Int
  package_activity_id      Int
  created_at               DateTime @default(now())

  package_location_slot PackageLocationSlot @relation(fields: [package_location_slot_id], references: [id], onDelete: Cascade)
  package_activity      PackageActivity     @relation(fields: [package_activity_id], references: [id], onDelete: Cascade)

  @@unique([package_location_slot_id, package_activity_id])
  @@index([package_location_slot_id])
  @@index([package_activity_id])
  @@map("location_activity_assignments")
}

// ─── Package Version History ─────────────────────────────────────────
// Tracks every saved version of a package for audit trail and rollback.

model PackageVersion {
  id             Int      @id @default(autoincrement())
  package_id     Int
  version_number Int
  snapshot       Json // Full package state at time of save
  change_summary String? // Optional user-provided or auto-generated summary
  created_at     DateTime @default(now())

  package service_packages @relation(fields: [package_id], references: [id], onDelete: Cascade)

  @@unique([package_id, version_number])
  @@index([package_id])
  @@map("package_versions")
}

// ─── Package Task Overrides ──────────────────────────────────────────
// When a package is assigned a workflow template, these overrides allow
// customization per-package: skip certain tasks, adjust hours, etc.

model PackageTaskOverride {
  id                      Int            @id @default(autoincrement())
  package_id              Int
  task_generation_rule_id Int? // If overriding a specific rule from the workflow template
  task_library_id         Int? // If linking to a task from the task library
  action                  String         @default("include") // "include" | "exclude" | "override"
  override_name           String? // Override the task name
  override_hours          Decimal?       @db.Decimal(8, 2) // Override estimated hours
  override_assignee_role  String? // Override the default assignee role
  phase                   project_phase? // Phase this task belongs to
  order_index             Int            @default(0)
  is_active               Boolean        @default(true)
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt

  package service_packages @relation(fields: [package_id], references: [id], onDelete: Cascade)

  @@index([package_id])
  @@map("package_task_overrides")
}

// ============================================================
// PACKAGE SETS - Curated collections of packages for client types
// ============================================================

model package_sets {
  id            Int      @id @default(autoincrement())
  brand_id      Int
  name          String
  description   String?
  emoji         String?  @default("📦")
  category_id   Int?
  event_type_id Int?
  order_index   Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  brand      brands                      @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  category   service_package_categories? @relation(fields: [category_id], references: [id], onDelete: SetNull)
  event_type EventType?                  @relation(fields: [event_type_id], references: [id], onDelete: SetNull)
  slots      package_set_slots[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@index([category_id])
  @@index([event_type_id])
  @@map("package_sets")
}

model package_set_slots {
  id                 Int      @id @default(autoincrement())
  package_set_id     Int
  service_package_id Int?
  slot_label         String   @default("Package")
  order_index        Int      @default(0)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  package_set     package_sets      @relation(fields: [package_set_id], references: [id], onDelete: Cascade)
  service_package service_packages? @relation(fields: [service_package_id], references: [id], onDelete: SetNull)

  @@index([package_set_id])
  @@index([service_package_id])
  @@map("package_set_slots")
}

// ─── Payment Schedule Templates ──────────────────────────────────────────────
// Reusable templates defining when and how much clients pay.
// e.g. "Standard 50/50", "3-way split", "Rush Booking Full Upfront"

model payment_schedule_templates {
  id          Int      @id @default(autoincrement())
  brand_id    Int
  name        String   // "Standard 50/50"
  description String?
  is_default  Boolean  @default(false)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  brand     brands                       @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  rules     payment_schedule_rules[]
  estimates estimates[]
  quotes    quotes[]
  contract_templates contract_templates[] @relation("contract_payment_schedule")
  inquiries  inquiries[]                  @relation("InquiryPreferredPaymentSchedule")

  @@unique([brand_id, name])
  @@index([brand_id])
  @@map("payment_schedule_templates")
}

model payment_schedule_rules {
  id           Int     @id @default(autoincrement())
  template_id  Int
  label        String  // "Booking Deposit", "Final Balance", "Post-Delivery"
  // PERCENT = percentage of estimate total; FIXED = fixed £ amount
  amount_type  String  @default("PERCENT") // PERCENT | FIXED
  amount_value Decimal @db.Decimal(10, 2)  // 50 (for 50%) or 500.00 (for £500)
  // When this payment is due relative to a reference date
  trigger_type String  // AFTER_BOOKING | BEFORE_EVENT | AFTER_EVENT | ON_DATE
  trigger_days Int?    // number of days offset; null if trigger_type = ON_DATE
  order_index  Int     @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  template payment_schedule_templates @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@map("payment_schedule_rules")
}

// ── Crew payment templates — role-based structured payment terms for crew ──
model crew_payment_templates {
  id            Int      @id @default(autoincrement())
  brand_id      Int
  name          String
  description   String?
  role_type     String   // "on_site" | "off_site"
  payment_terms String?  @default("DUE_ON_RECEIPT") // DUE_ON_RECEIPT | NET_7 | NET_14 | NET_30 | NET_60
  is_default    Boolean  @default(false)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  brand  brands                @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  rules  crew_payment_rules[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@map("crew_payment_templates")
}

model crew_payment_rules {
  id              Int     @id @default(autoincrement())
  template_id     Int
  label           String
  amount_type     String  @default("PERCENT") // PERCENT | FIXED
  amount_value    Decimal @db.Decimal(10, 2)
  trigger_type    String  // ON_BOOKING | ON_SHOOT_DAY | ON_COMPLETION | AFTER_DELIVERY | BEFORE_EVENT | AFTER_EVENT | ON_FIRST_EDIT | AFTER_ROUGH_CUT | NET_DAYS | ON_TASK_COMPLETE | RECURRING
  trigger_days    Int?
  task_library_id Int?    // FK → task_library(id), used when trigger_type = ON_TASK_COMPLETE
  frequency       String? // WEEKLY | FORTNIGHTLY | MONTHLY, used when trigger_type = RECURRING
  order_index     Int     @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  template     crew_payment_templates @relation(fields: [template_id], references: [id], onDelete: Cascade)
  task_library task_library?          @relation(fields: [task_library_id], references: [id], onDelete: SetNull)

  @@index([template_id])
  @@index([task_library_id])
  @@map("crew_payment_rules")
}

// Resolved milestones per estimate — concrete dates + amounts calculated at estimate creation/send time
model estimate_payment_milestones {
  id          Int      @id @default(autoincrement())
  estimate_id Int
  label       String   // "Booking Deposit"
  amount      Decimal  @db.Decimal(10, 2)
  due_date    DateTime
  status      String   @default("PENDING") // PENDING | PAID | OVERDUE | WAIVED
  notes       String?
  order_index Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  estimate estimates @relation(fields: [estimate_id], references: [id], onDelete: Cascade)

  @@index([estimate_id])
  @@map("estimate_payment_milestones")
}

// ---------------------------------------------------------------------------
// Contract Clause Settings
// ---------------------------------------------------------------------------

model contract_clause_categories {
  id           Int      @id @default(autoincrement())
  brand_id     Int
  name         String   // e.g. "Payment Terms", "Cancellation Policy"
  description  String?
  order_index  Int      @default(0)
  is_default   Boolean  @default(false) // seeded system defaults
  country_code String?  // ISO 3166-1 alpha-2 ("GB", "US") or null = universal
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  brand   brands             @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  clauses contract_clauses[]

  @@index([brand_id])
  @@index([brand_id, country_code])
  @@map("contract_clause_categories")
}

model contract_clauses {
  id           Int      @id @default(autoincrement())
  category_id  Int
  brand_id     Int
  title        String   // short label, e.g. "50% Non-Refundable Deposit"
  body         String   @db.Text // full clause text
  clause_type  String   @default("STANDARD") // STANDARD | EXTRA
  country_code String?  // ISO 3166-1 alpha-2 or null = universal
  is_default   Boolean  @default(false)
  is_active    Boolean  @default(true)
  order_index  Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  category contract_clause_categories @relation(fields: [category_id], references: [id], onDelete: Cascade)
  brand    brands                     @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  template_clauses contract_template_clauses[]

  @@index([category_id])
  @@index([brand_id])
  @@index([brand_id, clause_type])
  @@map("contract_clauses")
}

// ---------------------------------------------------------------------------
// Contract Templates – compose contracts from selected clauses
// ---------------------------------------------------------------------------

model contract_templates {
  id                          Int      @id @default(autoincrement())
  brand_id                    Int
  name                        String   // "Standard Wedding Contract", "Elopement Contract"
  description                 String?
  payment_schedule_template_id Int?    // optional link to a payment schedule
  is_default                  Boolean  @default(false)
  is_active                   Boolean  @default(true)
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  brand              brands                       @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  payment_schedule   payment_schedule_templates?   @relation("contract_payment_schedule", fields: [payment_schedule_template_id], references: [id], onDelete: SetNull)
  template_clauses   contract_template_clauses[]

  @@index([brand_id])
  @@map("contract_templates")
}

model contract_template_clauses {
  id            Int      @id @default(autoincrement())
  template_id   Int
  clause_id     Int
  order_index   Int      @default(0)
  override_body String?  @db.Text // optional per-template override of clause body
  created_at    DateTime @default(now())

  template contract_templates @relation(fields: [template_id], references: [id], onDelete: Cascade)
  clause   contract_clauses   @relation(fields: [clause_id], references: [id], onDelete: Cascade)

  @@unique([template_id, clause_id])
  @@index([template_id], map: "tmpl_clauses_template_id_idx")
  @@index([clause_id], map: "tmpl_clauses_clause_id_idx")
  @@map("contract_template_clauses")
}

model package_requests {
  id                 Int       @id @default(autoincrement())
  inquiry_id         Int
  selected_package_id Int?
  customisations     Json?
  notes              String?   @db.Text
  status             String    @default("pending")
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  inquiry            inquiries @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)

  @@index([inquiry_id])
  @@map("package_requests")
}


model inquiry_equipment_reservations {
  id                               Int                                      @id @default(autoincrement())
  inquiry_id                       Int
  equipment_id                     Int
  project_crew_slot_equipment_id   Int
  equipment_availability_id        Int?
  status                           inquiry_equipment_reservation_status     @default(reserved)
  reserved_at                      DateTime                                 @default(now())
  cancelled_at                     DateTime?
  created_at                       DateTime                                 @default(now())
  inquiry                          inquiries                                @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  equipment                        equipment                                @relation(fields: [equipment_id], references: [id], onDelete: Cascade)

  @@unique([inquiry_id, project_crew_slot_equipment_id])
  @@index([inquiry_id])
  @@index([equipment_id])
  @@map("inquiry_equipment_reservations")
}

enum inquiry_equipment_reservation_status {
  reserved
  confirmed
  cancelled
}
