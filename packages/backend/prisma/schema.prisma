generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model brands {
  id                 Int                @id @default(autoincrement())
  name               String             @unique
  display_name       String?
  description        String?
  business_type      String?
  website            String?
  email              String?
  phone              String?
  address_line1      String?
  address_line2      String?
  city               String?
  state              String?
  country            String             @default("United States")
  postal_code        String?
  timezone           String             @default("America/New_York")
  currency           String             @default("USD")
  logo_url           String?
  is_active          Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  brand_settings     brand_settings[]
  contacts           contacts[]
  equipment          equipment[]
  filmLibrary        filmLibrary[]
  floor_plan_objects FloorPlanObjects[]
  locations          LocationsLibrary[]
  music_library      MusicLibrary[]
  projects           projects[]
  roles              roles[]
  scenes             ScenesLibrary[]
  subjects           SubjectsLibrary[]
  task_library       task_library[]
  user_brands        user_brands[]

  @@map("brands")
}

model brand_settings {
  id          Int      @id @default(autoincrement())
  brand_id    Int
  key         String
  value       String
  data_type   String   @default("string")
  category    String?
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  brand       brands   @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@unique([brand_id, key])
  @@index([brand_id])
  @@index([category])
  @@map("brand_settings")
}

model user_brands {
  id        Int          @id @default(autoincrement())
  user_id   Int
  brand_id  Int
  role      String       @default("Member")
  is_active Boolean      @default(true)
  joined_at DateTime     @default(now())
  brand     brands       @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  user      contributors @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, brand_id])
  @@index([user_id])
  @@index([brand_id])
  @@map("user_brands")
}

model contacts {
  id                 Int                  @id @default(autoincrement())
  first_name         String?
  last_name          String?
  email              String               @unique
  phone_number       String?
  company_name       String?
  type               contacts_type
  brand_id           Int?
  archived_at        DateTime?
  activities         activities[]
  client             clients?
  communications_log communications_log[]
  brand              brands?              @relation(fields: [brand_id], references: [id])
  contributor        contributors?
  event_attendees    event_attendees[]
  inquiries          inquiries[]

  @@index([email])
  @@index([type])
  @@index([brand_id])
  @@map("contacts")
}

model coverage {
  id                         Int                          @id @default(autoincrement())
  name                       String                       @unique
  description                String?
  workflow_template_id       Int?
  recording_equipment        Json?
  aperture                   String?
  audio_equipment            AudioEquipment?
  camera_movement            CameraMovement?
  is_active                  Boolean                      @default(true)
  lens_focal_length          String?
  notes                      String?
  shot_type                  ShotType?
  subject                    String?
  coverage_type              CoverageType?
  audio_pattern              String?
  frequency_response         String?
  equipment_assignments      Json?
  operator_id                Int?
  is_template                Boolean                      @default(false)
  video_style_type           VideoStyleType?
  build_coverage_assignments build_coverage_assignments[]
  build_scenes               build_scenes[]
  operator                   contributors?                @relation("CoverageOperator", fields: [operator_id], references: [id])
  workflow_template          workflow_templates?          @relation(fields: [workflow_template_id], references: [id])
  project_assets             project_assets[]
  scene_coverage             SceneCoverage[]
  template_defaults          SceneTemplateDefaults[]
  task_generation_rules      task_generation_rules[]

  @@map("coverage")
}

model film_categories {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  description String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("film_categories")
}

model filmLibrary {
  id                   Int                      @id @default(autoincrement())
  name                 String                   @unique
  description          String?
  workflow_template_id Int?
  brand_id             Int?
  created_at           DateTime                 @default(now())
  default_music_type   MusicType?
  delivery_timeline    Int?
  includes_music       Boolean                  @default(true)
  is_active            Boolean                  @default(true)
  type                 FilmType                 @default(STANDARD)
  updated_at           DateTime                 @updatedAt
  version              String                   @default("1.0")
  build_films          build_films[]
  assigned_scenes      FilmAssignedScenes[]
  change_logs          FilmChangeLog[]
  brand                brands?                  @relation(fields: [brand_id], references: [id])
  workflow_template    workflow_templates?      @relation(fields: [workflow_template_id], references: [id])
  local_scenes         FilmLocalScenes[]
  music_tracks         FilmMusicTrack[]
  versions             FilmVersion[]
  template_defaults    SceneTemplateDefaults[]
  usage_analytics      SceneUsageAnalytics[]
  timeline_changes     TimelineChangeLog[]
  timeline_sessions    TimelineEditingSession[]
  timeline_scenes      TimelineScene[]

  @@index([brand_id])
  @@map("film_library")
}

model editing_styles {
  id                         Int                          @id @default(autoincrement())
  name                       String                       @unique
  description                String?
  workflow_template_id       Int?
  build_scenes               build_scenes[]
  editing_style_requirements editing_style_requirements[]
  workflow_template          workflow_templates?          @relation(fields: [workflow_template_id], references: [id])
  template_defaults          SceneTemplateDefaults[]

  @@map("editing_styles")
}

model ScenesLibrary {
  id                        Int                   @id @default(autoincrement())
  name                      String
  description               String?
  type                      MediaType
  is_coverage_linked        Boolean               @default(false)
  workflow_template_id      Int?
  brand_id                  Int?
  complexity_score          Int                   @default(5)
  estimated_duration        Int?
  default_editing_style     String?
  base_task_hours           Decimal               @default(0.00) @db.Decimal(5, 2)
  created_at                DateTime              @default(now())
  updated_at                DateTime              @updatedAt
  usage_count               Int?                  @default(0)
  last_used_at              DateTime?
  average_actual_duration   Decimal?              @db.Decimal(8, 2)
  performance_score         Decimal?              @default(5.0) @db.Decimal(3, 2)
  computed_task_count       Int?
  computed_total_hours      Decimal?              @db.Decimal(8, 2)
  default_coverage_duration Int?                  @default(30)
  film_assignments          FilmAssignedScenes[]
  film_local_copies         FilmLocalScenes[]     @relation("FilmLocalToOriginal")
  coverage                  SceneCoverage[]
  dependent_scenes          SceneDependency[]     @relation("DependentScene")
  parent_dependencies       SceneDependency[]     @relation("ParentDependency")
  location_space            SceneLocationSpace?
  media_components          SceneMediaComponent[]
  moments                   SceneMoments[]
  scene_subjects            SceneSubjects[]
  usage_analytics           SceneUsageAnalytics[]
  brand                     brands?               @relation(fields: [brand_id], references: [id])
  workflow_template         workflow_templates?   @relation(fields: [workflow_template_id], references: [id])
  timeline_changes          TimelineChangeLog[]
  timeline_scenes           TimelineScene[]

  @@index([brand_id])
  @@map("scenes_library")
}

model SubjectsLibrary {
  id               Int             @id @default(autoincrement())
  first_name       String
  last_name        String?
  context_role     String
  hair_color       String?
  hair_style       String?
  skin_tone        String?
  height           String?
  eye_color        String?
  appearance_notes String?
  brand_id         Int?
  is_active        Boolean         @default(true)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  scene_subjects   SceneSubjects[]
  brand            brands?         @relation(fields: [brand_id], references: [id])

  @@index([brand_id])
  @@index([context_role])
  @@map("subjects_library")
}

model SceneSubjects {
  id         Int             @id @default(autoincrement())
  scene_id   Int
  subject_id Int
  priority   SubjectPriority @default(SECONDARY)
  notes      String?
  created_at DateTime        @default(now())
  updated_at DateTime        @updatedAt
  scene      ScenesLibrary   @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  subject    SubjectsLibrary @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([scene_id, subject_id])
  @@index([scene_id])
  @@index([subject_id])
  @@index([priority])
  @@map("scene_subjects")
}

model FilmAssignedScenes {
  film_id               Int
  scene_id              Int
  order_index           Int
  editing_style         String?
  duration_override     Int?
  calculated_task_hours Decimal?      @db.Decimal(5, 2)
  calculated_base_price Decimal?      @db.Decimal(10, 2)
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt
  film                  filmLibrary   @relation(fields: [film_id], references: [id], onDelete: Cascade)
  scene                 ScenesLibrary @relation(fields: [scene_id], references: [id])

  @@id([film_id, scene_id])
  @@map("film_assigned_scenes")
}

model FilmLocalScenes {
  id                    Int                            @id @default(autoincrement())
  film_id               Int
  original_scene_id     Int?
  name                  String
  type                  MediaType
  description           String?
  complexity_score      Int?                           @default(5)
  estimated_duration    Int?                           @default(60)
  default_editing_style String?
  base_task_hours       Decimal?                       @db.Decimal(5, 2)
  order_index           Int
  editing_style         String?
  duration_override     Int?
  calculated_task_hours Decimal?                       @db.Decimal(5, 2)
  calculated_base_price Decimal?                       @db.Decimal(10, 2)
  created_at            DateTime                       @default(now())
  updated_at            DateTime                       @updatedAt
  media_components      FilmLocalSceneMediaComponent[]
  film                  filmLibrary                    @relation(fields: [film_id], references: [id], onDelete: Cascade)
  original_scene        ScenesLibrary?                 @relation("FilmLocalToOriginal", fields: [original_scene_id], references: [id])

  @@index([film_id])
  @@index([original_scene_id])
  @@map("film_local_scenes")
}

model FilmLocalSceneMediaComponent {
  id                    Int                  @id @default(autoincrement())
  film_local_scene_id   Int
  original_component_id Int?
  media_type            String
  duration_seconds      Int
  is_primary            Boolean              @default(false)
  music_type            MusicType?
  music_weight          Int?                 @default(5)
  notes                 String?
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt
  film_local_scene      FilmLocalScenes      @relation(fields: [film_local_scene_id], references: [id], onDelete: Cascade)
  original_component    SceneMediaComponent? @relation("FilmLocalToOriginalComponent", fields: [original_component_id], references: [id])

  @@index([film_local_scene_id])
  @@index([original_component_id])
  @@map("film_local_scene_media_components")
}

model SceneCoverage {
  scene_id       Int
  coverage_id    Int
  priority_order Int           @default(1)
  moment_id      Int?
  assignment     String?
  coverage       coverage      @relation(fields: [coverage_id], references: [id])
  moment         SceneMoments? @relation(fields: [moment_id], references: [id])
  scene          ScenesLibrary @relation(fields: [scene_id], references: [id], onDelete: Cascade)

  @@id([scene_id, coverage_id])
  @@map("scene_coverage")
}

model MomentTemplates {
  id               Int                     @id @default(autoincrement())
  name             String
  description      String?
  scene_type       String?
  order_index      Int                     @default(0)
  default_duration Int?                    @default(60)
  is_active        Boolean                 @default(true)
  created_at       DateTime                @default(now())
  updated_at       DateTime                @updatedAt
  project_defaults ProjectMomentDefaults[]
  scene_moments    SceneMoments[]

  @@map("moment_templates")
}

model ProjectMomentDefaults {
  id               Int             @id @default(autoincrement())
  project_id       Int
  template_id      Int
  name             String
  description      String?
  order_index      Int             @default(0)
  default_duration Int?            @default(60)
  is_active        Boolean         @default(true)
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  project          projects        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  template         MomentTemplates @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@unique([project_id, template_id])
  @@map("project_moment_defaults")
}

model SceneMoments {
  id             Int               @id @default(autoincrement())
  scene_id       Int
  project_id     Int?
  template_id    Int?
  name           String
  description    String?
  order_index    Int               @default(0)
  duration       Int?              @default(60)
  is_active      Boolean           @default(true)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  coverage_items SceneCoverage[]
  music          SceneMomentMusic?
  project        projects?         @relation(fields: [project_id], references: [id])
  scene          ScenesLibrary     @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  template       MomentTemplates?  @relation(fields: [template_id], references: [id])

  @@unique([scene_id, order_index])
  @@map("scene_moments")
}

model SceneMomentMusic {
  id         Int          @id @default(autoincrement())
  moment_id  Int          @unique
  music_name String?
  artist     String?
  duration   Int?
  music_type MusicType    @default(NONE)
  file_path  String?
  notes      String?
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  moment     SceneMoments @relation(fields: [moment_id], references: [id], onDelete: Cascade)

  @@map("scene_moment_music")
}

model FilmMusicTrack {
  id          Int         @id @default(autoincrement())
  film_id     Int
  music_type  MusicType
  track_name  String?
  artist      String?
  duration    Int?
  order_index Int         @default(0)
  film        filmLibrary @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@map("film_music_tracks")
}

model MusicLibrary {
  id                Int       @id @default(autoincrement())
  music_name        String?
  artist            String?
  duration          Int?
  music_type        MusicType @default(MODERN)
  file_path         String?
  notes             String?
  project_id        Int?
  brand_id          Int?
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  assignment_number String?
  brand             brands?   @relation(fields: [brand_id], references: [id])
  project           projects? @relation(fields: [project_id], references: [id])

  @@map("music_library")
}

model PricingModifier {
  id         Int                 @id @default(autoincrement())
  name       String
  type       PricingModifierType
  multiplier Decimal             @db.Decimal(4, 2)
  is_active  Boolean             @default(true)
  conditions Json?
  created_at DateTime            @default(now())
  updated_at DateTime            @updatedAt

  @@map("pricing_modifiers")
}

model FilmVersion {
  id               Int          @id @default(autoincrement())
  film_id          Int
  version_number   String
  change_summary   String
  changed_by_id    Int
  created_at       DateTime     @default(now())
  scenes_snapshot  Json
  pricing_snapshot Json
  changed_by       contributors @relation("FilmVersionCreator", fields: [changed_by_id], references: [id])
  film             filmLibrary  @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@map("film_versions")
}

model FilmChangeLog {
  id            Int          @id @default(autoincrement())
  film_id       Int
  change_type   String
  old_value     Json?
  new_value     Json?
  changed_by_id Int
  created_at    DateTime     @default(now())
  changed_by    contributors @relation("FilmChangeUser", fields: [changed_by_id], references: [id])
  film          filmLibrary  @relation(fields: [film_id], references: [id], onDelete: Cascade)

  @@map("film_change_logs")
}

model operator_types {
  id                         Int                          @id @default(autoincrement())
  name                       String                       @unique
  default_hourly_rate        Decimal?                     @db.Decimal(8, 2)
  default_fixed_price        Decimal?                     @db.Decimal(10, 2)
  pricing_type               pricing_type_options         @default(Hourly)
  build_coverage_assignments build_coverage_assignments[]

  @@map("operator_types")
}

model billable_items {
  id                         Int                          @id @default(autoincrement())
  name                       String                       @unique
  description                String?
  category                   String?
  price                      Decimal                      @db.Decimal(10, 2)
  pricing_type               billable_item_pricing_type   @default(Fixed)
  is_active                  Boolean                      @default(true)
  build_billable_items       build_billable_items[]
  editing_style_requirements editing_style_requirements[]

  @@map("billable_items")
}

model task_templates {
  id                          Int                           @id @default(autoincrement())
  name                        String                        @unique
  phase                       String?
  effort_hours                Decimal?                      @db.Decimal(8, 2)
  effort_calculation_rules    Json?
  pricing_type                pricing_type_options          @default(Hourly)
  fixed_price                 Decimal?                      @db.Decimal(10, 2)
  average_duration_hours      Decimal?                      @db.Decimal(8, 2)
  contributor_skill_rates     contributor_skill_rates[]
  contributor_task_benchmarks contributor_task_benchmarks[]
  entity_default_tasks        entity_default_tasks[]
  task_generation_rules       task_generation_rules[]
  tasks                       tasks[]

  @@map("task_templates")
}

model roles {
  id                  Int                   @id @default(autoincrement())
  name                String                @unique
  description         String?
  brand_id            Int?
  contributors        contributors[]
  project_assignments project_assignments[]
  role_permissions    role_permissions[]
  brand               brands?               @relation(fields: [brand_id], references: [id])

  @@index([brand_id])
  @@map("roles")
}

model permissions {
  id               Int                @id @default(autoincrement())
  action_name      String             @unique
  description      String?
  role_permissions role_permissions[]

  @@map("permissions")
}

model role_permissions {
  role_id       Int
  permission_id Int
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@map("role_permissions")
}

model inquiries {
  id                  Int               @id @default(autoincrement())
  contact_id          Int
  wedding_date        DateTime?
  status              inquiries_status  @default(New)
  notes               String?
  venue_details       String?
  follow_up_due_date  DateTime?
  lead_source         String?
  lead_source_details String?
  campaign_id         String?
  archived_at         DateTime?
  workflow_status     Json?
  activities          activities[]
  activity_logs       activity_logs[]
  build               builds?
  calendar_events     calendar_events[]
  client              clients?
  contracts           contracts[]
  documents           documents[]
  estimates           estimates[]
  contact             contacts          @relation(fields: [contact_id], references: [id])
  invoices            invoices[]
  proposals           proposals[]
  quotes              quotes[]

  @@map("inquiries")
}

model activity_logs {
  id          Int       @id @default(autoincrement())
  inquiry_id  Int
  type        String
  description String
  created_at  DateTime  @default(now())
  inquiry     inquiries @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model clients {
  id                     Int                      @id @default(autoincrement())
  contact_id             Int                      @unique
  inquiry_id             Int?                     @unique
  archived_at            DateTime?
  builds                 builds[]
  client_user            client_users?
  contact                contacts                 @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  inquiry                inquiries?               @relation(fields: [inquiry_id], references: [id])
  equipment_availability equipment_availability[]
  equipment_rentals      equipment_rentals[]
  projects               projects[]

  @@map("clients")
}

model client_users {
  id              Int       @id @default(autoincrement())
  client_id       Int       @unique
  email           String    @unique
  password_hash   String
  last_login_date DateTime?
  client          clients   @relation(fields: [client_id], references: [id], onDelete: Cascade)

  @@map("client_users")
}

model projects {
  id                      Int                       @id @default(autoincrement())
  client_id               Int
  workflow_template_id    Int?
  brand_id                Int?
  project_name            String?
  wedding_date            DateTime
  booking_date            DateTime?
  edit_start_date         DateTime?
  phase                   String?
  archived_at             DateTime?
  activities              activities[]
  build                   builds?
  calendar_events         calendar_events[]
  client_feedback_surveys client_feedback_surveys[]
  communications_log      communications_log[]
  contracts               contracts[]
  documents               documents[]
  equipment_availability  equipment_availability[]
  equipment_rentals       equipment_rentals[]
  estimates               estimates[]
  floor_plans             FloorPlans[]
  generated_task_logs     generated_task_log[]
  invoices                invoices[]
  music_library           MusicLibrary[]
  project_assets          project_assets[]
  project_assignments     project_assignments[]
  project_expenses        project_expenses[]
  moment_defaults         ProjectMomentDefaults[]
  brand                   brands?                   @relation(fields: [brand_id], references: [id])
  client                  clients                   @relation(fields: [client_id], references: [id])
  workflow_template       workflow_templates?       @relation(fields: [workflow_template_id], references: [id])
  proposals               proposals[]
  quotes                  quotes[]
  scene_moments           SceneMoments[]
  tasks                   tasks[]

  @@unique([client_id, wedding_date])
  @@index([wedding_date])
  @@index([brand_id])
  @@map("projects")
}

model contributors {
  id                             Int                           @id @default(autoincrement())
  contact_id                     Int                           @unique
  role_id                        Int?
  contributor_type               contributors_type?
  password_hash                  String
  archived_at                    DateTime?
  default_hourly_rate            Decimal                       @default(0.00) @db.Decimal(8, 2)
  activities_assigned            activities[]
  audit_logs                     audit_log[]
  calendar_events                calendar_events[]
  calendar_settings              calendar_settings?
  calendar_sync_token            calendar_sync_tokens?
  job_roles_assigned             contributor_job_roles[]       @relation("JobRoleAssignedBy")
  contributor_job_roles          contributor_job_roles[]
  contributor_skill_rates        contributor_skill_rates[]
  contributor_task_benchmarks    contributor_task_benchmarks[]
  contact                        contacts                      @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  role                           roles?                        @relation(fields: [role_id], references: [id], onDelete: Restrict)
  coverage_assignments           coverage[]                    @relation("CoverageOperator")
  equipment_created              equipment[]                   @relation("EquipmentCreatedBy")
  equipment_booked               equipment_availability[]      @relation("EquipmentBookedBy")
  equipment_availability_created equipment_availability[]      @relation("EquipmentAvailabilityCreatedBy")
  equipment_maintenance          equipment_maintenance[]
  equipment_rented               equipment_rentals[]
  event_attendees                event_attendees[]
  film_changes_made              FilmChangeLog[]               @relation("FilmChangeUser")
  film_versions_created          FilmVersion[]                 @relation("FilmVersionCreator")
  floor_plans_created            FloorPlans[]                  @relation("FloorPlanCreatedBy")
  venue_floor_plans_updated      LocationsLibrary[]            @relation("VenueFloorPlanUpdater")
  notifications_received         notifications[]
  project_assignments            project_assignments[]
  scene_dependencies_created     SceneDependency[]
  usage_analytics_created        SceneUsageAnalytics[]
  task_comments_made             task_comments[]
  task_library_benchmarks        task_library_benchmarks[]
  tasks_assigned                 tasks[]                       @relation("AssignedTasks")
  timeline_changes_made          TimelineChangeLog[]
  timeline_sessions              TimelineEditingSession[]
  timeline_scenes_created        TimelineScene[]
  user_brands                    user_brands[]

  @@map("contributors")
}

model contributor_skill_rates {
  id               Int            @id @default(autoincrement())
  contributor_id   Int
  task_template_id Int
  rate             Decimal        @db.Decimal(8, 2)
  contributor      contributors   @relation(fields: [contributor_id], references: [id], onDelete: Cascade)
  task_template    task_templates @relation(fields: [task_template_id], references: [id], onDelete: Cascade)

