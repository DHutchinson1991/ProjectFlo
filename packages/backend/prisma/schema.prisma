model service_packages {
  id              Int      @id @default(autoincrement())
  brand_id        Int
  wedding_type_id Int? // Which wedding type this package was created from (optional)
  name            String
  description     String?
  category        String? // Keeping for backward compat, or allows free text if no relation
  category_id     Int? // New flexible relation
  currency        String   @default("USD")
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // JSON field to store the package contents (Films, coverage, add-ons)
  // Structure: { films: [id, id], line_items: [{description, price}] }
  contents Json?

  brand                brands                      @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  package_category     service_package_categories? @relation(fields: [category_id], references: [id])
  wedding_type         EventSubtype?                @relation("CreatedFromEventSubtype", fields: [wedding_type_id], references: [id], onDelete: SetNull)
  inquiries            inquiries[]
  inquiry_source_refs   inquiries[]             @relation("InquirySourcePackage")
  projects_from_package projects[]              @relation("ProjectSourcePackage")
  workflow_template_id Int? // Default workflow template for projects using this package

  package_films               PackageFilm[]
  package_event_days          PackageEventDay[]
  package_crew_slots          PackageCrewSlot[]
  package_activities          PackageActivity[]
  package_day_subjects        PackageDaySubject[]
  package_event_day_locations PackageEventDayLocation[]
  package_location_slots      PackageLocationSlot[]
  package_versions            PackageVersion[]
  package_task_overrides      PackageTaskOverride[]
  package_set_slots            package_set_slots[]
  project_tasks               project_tasks[]
  workflow_template           workflow_templates?       @relation(fields: [workflow_template_id], references: [id], onDelete: SetNull)

  @@index([brand_id])
  @@index([category_id])
  @@index([wedding_type_id])
  @@index([workflow_template_id])
  @@map("service_packages")
}

model service_package_categories {
  id            Int      @id @default(autoincrement())
  brand_id      Int
  name          String
  description   String?
  order_index   Int      @default(0)
  is_active     Boolean  @default(true)
  event_type_id Int?     // FK → event_types; populated automatically when EventType is created
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  brand      brands             @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  event_type EventType?         @relation(fields: [event_type_id], references: [id], onDelete: SetNull)
  packages   service_packages[]
  package_sets package_sets[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@index([event_type_id])
  @@map("service_package_categories")
}

// ============================================================
// SCHEDULE SYSTEM - Event Days, Film Schedules, Inheritance Chain
// Film (defaults) → Package (overrides) → Project (actual)
// ============================================================

// Brand-level shared schedule presets
model SchedulePreset {
  id            Int      @id @default(autoincrement())
  brand_id      Int
  name          String
  schedule_data Json
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  brand brands @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@unique([brand_id, name])
  @@index([brand_id])
  @@map("schedule_presets")
}

// ─── Event Types ──────────────────────────────────────────────────────
// Top-level event categories (e.g., "Wedding", "Corporate", "Birthday")
// Groups event days and subject types into a coherent template
// Used by the Package Creation Wizard to stamp out packages

model EventType {
  id                     Int      @id @default(autoincrement())
  brand_id               Int
  name                   String // "Wedding", "Corporate", "Birthday"
  description            String?
  icon                   String? // Icon identifier (e.g., "heart", "cake")
  color                  String? // Hex color for UI
  default_duration_hours Int? // Typical total event duration
  default_start_time     String? // "HH:MM" e.g., "14:00"
  typical_guest_count    Int? // Reference guide
  is_system              Boolean  @default(false) // System-seeded vs user-created
  is_active              Boolean  @default(true)
  order_index            Int      @default(0)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  brand              brands                      @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  event_days         EventTypeDay[]
  subject_roles      EventTypeSubject[]
  event_subtypes     EventSubtype[]
  inquiries          inquiries[]
  package_categories service_package_categories[]
  package_sets       package_sets[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@index([is_system])
  @@index([is_active])
  @@map("event_types")
}

// Junction: EventType ↔ EventDay (many-to-many)
// Optional event_subtype_id narrows this day to a specific subtype (e.g., Indian Wedding)
model EventTypeDay {
  id                    Int      @id @default(autoincrement())
  event_type_id         Int
  event_day_template_id Int
  event_subtype_id      Int? // Nullable: when set, this day only applies to the given subtype
  order_index           Int      @default(0)
  is_default            Boolean  @default(true) // Pre-selected in wizard
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  event_type         EventType        @relation(fields: [event_type_id], references: [id], onDelete: Cascade)
  event_day_template EventDay @relation(fields: [event_day_template_id], references: [id], onDelete: Cascade)
  event_subtype      EventSubtype?    @relation(fields: [event_subtype_id], references: [id], onDelete: SetNull)

  @@unique([event_type_id, event_day_template_id])
  @@index([event_type_id])
  @@index([event_day_template_id])
  @@index([event_subtype_id])
  @@map("event_type_days")
}

// Junction: EventType ↔ SubjectRole (many-to-many)
model EventTypeSubject {
  id              Int      @id @default(autoincrement())
  event_type_id   Int
  subject_role_id Int
  order_index     Int      @default(0)
  is_default      Boolean  @default(true) // Pre-selected in wizard
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  event_type   EventType   @relation(fields: [event_type_id], references: [id], onDelete: Cascade)
  subject_role SubjectRole @relation(fields: [subject_role_id], references: [id], onDelete: Cascade)

  @@unique([event_type_id, subject_role_id])
  @@index([event_type_id])
  @@index([subject_role_id])
  @@map("event_type_subjects")
}

// Brand-level event days (e.g., "Rehearsal Dinner", "Wedding Day", "Reception")
// EventDay is the single source of truth for activities, moments, subjects, and locations
model EventDay {
  id                     Int      @id @default(autoincrement())
  brand_id               Int
  name                   String
  description            String?
  default_start_time     String? // "HH:MM" e.g., "14:00"
  default_duration_hours Int?    // Typical duration for this day type
  icon                   String? // Icon identifier for UI
  color                  String? // Hex color for UI
  order_index            Int      @default(0)
  is_active              Boolean  @default(true)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  brand                       brands                     @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  activity_presets             EventDayActivity[]
  subject_roles               EventDaySubjectRole[]
  event_type_days             EventTypeDay[]
  film_scene_schedules        FilmSceneSchedule[]
  package_scene_schedules     PackageFilmSceneSchedule[]
  project_event_days          ProjectEventDay[]
  package_event_days          PackageEventDay[]
  package_day_subjects        PackageDaySubject[]
  package_event_day_locations PackageEventDayLocation[]
  package_location_slots      PackageLocationSlot[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@map("event_days")
}

// Activity presets for each event day template type
// e.g., "Wedding Day" → Bridal Prep, Ceremony, Reception
// "Rehearsal Dinner" → Welcome Drinks, Rehearsal, Dinner
// These populate the Add Activity dialog dropdown per event day type
model EventDayActivity {
  id                       Int      @id @default(autoincrement())
  event_day_template_id    Int
  name                     String // "Bridal Prep", "Ceremony", etc.
  description              String? // Short description of the activity
  color                    String? // Hex color, e.g., "#ec4899"
  icon                     String? // Icon identifier
  default_start_time       String? // Default "HH:MM" start time, e.g. "14:00"
  default_duration_minutes Int?    // Suggested duration in minutes
  order_index              Int      @default(0)
  is_active                Boolean  @default(true)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  event_day_template EventDay               @relation(fields: [event_day_template_id], references: [id], onDelete: Cascade)
  moments            EventDayActivityMoment[]

  @@unique([event_day_template_id, name])
  @@index([event_day_template_id])
  @@map("event_day_activities")
}

// Default moments within an activity preset
// e.g., "Ceremony" → Processional, Vows, Ring Exchange, First Kiss, Recessional
// These auto-populate when an activity is added from a preset
model EventDayActivityMoment {
  id                          Int      @id @default(autoincrement())
  event_day_activity_preset_id Int
  name                        String // "Processional", "Vows", etc.
  description                 String? // Short description of the moment
  duration_seconds            Int      @default(60)
  order_index                 Int      @default(0)
  is_key_moment               Boolean  @default(false) // Mark for highlight reel
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  activity_preset EventDayActivity @relation(fields: [event_day_activity_preset_id], references: [id], onDelete: Cascade)

  @@unique([event_day_activity_preset_id, order_index])
  @@index([event_day_activity_preset_id])
  @@map("event_day_activity_moments")
}

// ─── Event Day Subject Roles ─────────────────────────────────────────
// Which subject roles are relevant for this event day
// e.g., "Wedding Day" → Bride, Groom, Bridesmaids, Groomsmen
model EventDaySubjectRole {
  id              Int      @id @default(autoincrement())
  event_day_id    Int
  subject_role_id Int
  is_primary      Boolean  @default(false) // Primary focus for this day
  order_index     Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  event_day    EventDay    @relation(fields: [event_day_id], references: [id], onDelete: Cascade)
  subject_role SubjectRole @relation(fields: [subject_role_id], references: [id], onDelete: Cascade)

  @@unique([event_day_id, subject_role_id])
  @@index([event_day_id])
  @@index([subject_role_id])
  @@map("event_day_subject_roles")
}

// ─── Event Subtypes ──────────────────────────────────────────────────
// Cultural/style variations within an event type (e.g., "Indian Wedding", "Traditional British Wedding")
// Each subtype has a standard set of activities suitable for that culture/style
model EventSubtype {
  id                   Int      @id @default(autoincrement())
  brand_id             Int? // Brand-specific override, NULL = system default
  event_type_id        Int? // Which event type this subtype belongs to (e.g., Wedding → Indian Wedding)
  name                 String // "Traditional British Wedding", "Indian Wedding", etc.
  description          String?
  total_duration_hours Int // e.g., 10 for British, 14 for Indian
  event_start_time     String // "HH:MM" e.g., "14:00" or "12:00"
  typical_guest_count  Int? // Reference guide for this wedding type
  is_system_seeded     Boolean  @default(true) // System defaults vs user-created
  is_active            Boolean  @default(true)
  order_index          Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  brand                    brands?               @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  event_type               EventType?            @relation(fields: [event_type_id], references: [id], onDelete: SetNull)
  activities               EventSubtypeActivity[]
  locations                EventSubtypeLocation[]
  subjects                 EventSubtypeSubject[]
  event_type_days          EventTypeDay[]
  service_packages_created service_packages[]    @relation("CreatedFromEventSubtype")

  @@unique([brand_id, name])
  @@index([brand_id])
  @@index([event_type_id])
  @@index([is_system_seeded])
  @@index([is_active])
  @@map("event_subtypes")
}

// Activities within a wedding type template
// These auto-populate into the package when created "from" this wedding type
model EventSubtypeActivity {
  id                        Int      @id @default(autoincrement())
  wedding_type_id           Int
  name                      String // "Getting Ready", "Ceremony", "Reception", etc.
  icon                      String? // Icon identifier (e.g., "glam", "heart", "cake")
  color                     String? // Hex color for Gantt visualization
  duration_minutes          Int // Activity block duration (e.g., 60, 90)
  start_time_offset_minutes Int // Minutes from event_start_time (e.g., 0, 60, 120)
  order_index               Int      @default(0)
  description               String?
  created_at                DateTime @default(now())
  updated_at                DateTime @updatedAt

  wedding_type       EventSubtype                   @relation(fields: [wedding_type_id], references: [id], onDelete: Cascade)
  moments            EventSubtypeActivityMoment[]
  activity_locations EventSubtypeActivityLocation[]
  activity_subjects  EventSubtypeActivitySubject[]

  @@unique([wedding_type_id, order_index])
  @@index([wedding_type_id])
  @@map("event_subtype_activities")
}

// Moments within a wedding type activity
// These auto-populate into the PackageActivityMoment when package is created
model EventSubtypeActivityMoment {
  id                       Int      @id @default(autoincrement())
  wedding_type_activity_id Int
  name                     String // "Processional", "Vows", "First Dance", "Cutting Cake", etc.
  duration_seconds         Int      @default(60) // Estimated moment duration
  order_index              Int      @default(0)
  is_key_moment            Boolean  @default(false) // Mark for highlight reel inclusion
  description              String?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  wedding_type_activity EventSubtypeActivity @relation(fields: [wedding_type_activity_id], references: [id], onDelete: Cascade)

  @@unique([wedding_type_activity_id, order_index])
  @@index([wedding_type_activity_id])
  @@map("event_subtype_activity_moments")
}

// Locations for a wedding type template
// e.g., "Bride's Home", "Venue", "Reception Hall", "Garden"
model EventSubtypeLocation {
  id              Int      @id @default(autoincrement())
  wedding_type_id Int
  name            String // "Bride's Getting Ready", "Ceremony Venue", "Reception Hall", etc.
  location_type   String? // "getting_ready", "ceremony", "reception", "photo", etc.
  order_index     Int      @default(0)
  is_primary      Boolean  @default(false) // Main/primary location for this type
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  wedding_type       EventSubtype                   @relation(fields: [wedding_type_id], references: [id], onDelete: Cascade)
  activity_locations EventSubtypeActivityLocation[]

  @@unique([wedding_type_id, order_index])
  @@index([wedding_type_id])
  @@map("event_subtype_locations")
}

// Subjects for a wedding type template
// e.g., "Bride", "Groom", "Bridesmaids", "Family", "Guests"
model EventSubtypeSubject {
  id              Int      @id @default(autoincrement())
  wedding_type_id Int
  name            String // "Bride", "Groom", "Bridesmaids", "Groomsmen", "Parents", "Family", "Guests"
  subject_type    String? // "couple", "wedding_party", "family", "guests", "children", "pets"
  subject_role_id Int? // FK → SubjectRole for canonical role matching
  typical_count   Int? // For "Bridesmaids": 3, "Guests": 80, etc.
  order_index     Int      @default(0)
  is_primary      Boolean  @default(false) // Core/primary subject type
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  wedding_type      EventSubtype                  @relation(fields: [wedding_type_id], references: [id], onDelete: Cascade)
  subject_role      SubjectRole?                  @relation(fields: [subject_role_id], references: [id], onDelete: SetNull)
  activity_subjects EventSubtypeActivitySubject[]

  @@unique([wedding_type_id, order_index])
  @@index([wedding_type_id])
  @@index([subject_role_id])
  @@map("event_subtype_subjects")
}

// Junction table: Activity -> Locations (many-to-many)
model EventSubtypeActivityLocation {
  id                           Int      @id @default(autoincrement())
  wedding_type_activity_id     Int
  wedding_type_location_id     Int
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt

  wedding_type_activity EventSubtypeActivity @relation(fields: [wedding_type_activity_id], references: [id], onDelete: Cascade)
  wedding_type_location EventSubtypeLocation @relation(fields: [wedding_type_location_id], references: [id], onDelete: Cascade)

  @@unique([wedding_type_activity_id, wedding_type_location_id])
  @@index([wedding_type_activity_id])
  @@index([wedding_type_location_id])
  @@map("event_subtype_activity_locations")
}

// Junction table: Activity -> Subjects (many-to-many)
model EventSubtypeActivitySubject {
  id                       Int      @id @default(autoincrement())
  wedding_type_activity_id Int
  wedding_type_subject_id  Int
  presence_percentage      Int? // How much of activity features this subject (0-100%)
  is_primary_focus         Boolean  @default(false)
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  wedding_type_activity EventSubtypeActivity @relation(fields: [wedding_type_activity_id], references: [id], onDelete: Cascade)
  wedding_type_subject  EventSubtypeSubject  @relation(fields: [wedding_type_subject_id], references: [id], onDelete: Cascade)

  @@unique([wedding_type_activity_id, wedding_type_subject_id])
  @@index([wedding_type_activity_id])
  @@index([wedding_type_subject_id])
  @@map("event_subtype_activity_subjects")
}

// Film-level scene schedule defaults (1:1 with FilmScene)
// Stores when a scene typically happens during an event day
model FilmSceneSchedule {
  id                         Int      @id @default(autoincrement())
  film_id                    Int
  scene_id                   Int      @unique
  event_day_template_id      Int?
  scheduled_start_time       String? // "HH:MM" format, e.g., "14:00"
  scheduled_duration_minutes Int? // Real-world filming duration (NOT edit duration)
  moment_schedules           Json? // [{moment_id, start_time, duration_minutes}]
  beat_schedules             Json? // [{beat_id, start_time, duration_minutes}]
  notes                      String?
  order_index                Int      @default(0)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  film      Film              @relation(fields: [film_id], references: [id], onDelete: Cascade)
  scene     FilmScene         @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  event_day EventDay? @relation(fields: [event_day_template_id], references: [id], onDelete: SetNull)

  @@index([film_id])
  @@index([event_day_template_id])
  @@map("film_scene_schedules")
}

// Proper join table: Package ↔ Event Day (which event days apply to this package)
model PackageEventDay {
  id                    Int      @id @default(autoincrement())
  package_id            Int
  event_day_template_id Int
  order_index           Int      @default(0)
  created_at            DateTime @default(now())

  package    service_packages  @relation(fields: [package_id], references: [id], onDelete: Cascade)
  event_day  EventDay  @relation(fields: [event_day_template_id], references: [id], onDelete: Cascade)
  activities PackageActivity[]
  crew_slots PackageCrewSlot[]

  @@unique([package_id, event_day_template_id])
  @@index([package_id])
  @@index([event_day_template_id])
  @@map("package_event_days")
}

// ─── Activities (real-world schedule blocks within an event day) ──────
// Activities represent what actually happens during a day: Bridal Prep, Ceremony,
// Reception, Portraits, etc. Film scenes and crew slots are assigned TO activities.

// Package-level activities (template schedule blocks)
model PackageActivity {
  id                   Int      @id @default(autoincrement())
  package_id           Int
  package_event_day_id Int
  name                 String // "Bridal Prep", "Ceremony", "Reception", etc.
  description          String?
  color                String? // Hex color for Gantt visualization
  icon                 String? // Icon identifier (e.g. "church", "ring", "cake")
  start_time           String? // "HH:MM" format, e.g. "14:00"
  end_time             String? // "HH:MM" format, e.g. "15:30"
  duration_minutes     Int? // Estimated duration (alternative to end_time)
  order_index          Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  package              service_packages             @relation(fields: [package_id], references: [id], onDelete: Cascade)
  package_event_day    PackageEventDay              @relation(fields: [package_event_day_id], references: [id], onDelete: Cascade)
  scene_schedules      PackageFilmSceneSchedule[]
  locations            PackageEventDayLocation[]
  project_activities   ProjectActivity[]
  crew_slot_assignments PackageCrewSlotActivity[]
  subject_assignments  PackageDaySubjectActivity[]
  location_assignments LocationActivityAssignment[]
  moments              PackageActivityMoment[]
  beat_sources         SceneBeat[]
  audio_sources        SceneAudioSource[]

  @@index([package_id])
  @@index([package_event_day_id])
  @@map("package_activities")
}

// ─── Activity-level moments (auto-populate into scenes linked to activities) ──
model PackageActivityMoment {
  id                  Int      @id @default(autoincrement())
  package_activity_id Int
  name                String // "Processional", "Vows", "First Dance", etc.
  order_index         Int      @default(0)
  duration_seconds    Int      @default(60) // Default estimated duration in seconds
  is_required         Boolean  @default(true) // Whether this moment must appear in linked scenes
  notes               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  package_activity PackageActivity @relation(fields: [package_activity_id], references: [id], onDelete: Cascade)
  beat_sources     SceneBeat[]     @relation("BeatSourceMoment")
  audio_sources    SceneAudioSource[] @relation("AudioSourceMoment")

  @@unique([package_activity_id, order_index])
  @@index([package_activity_id])
  @@map("package_activity_moments")
}

// ─── Package Crew Slots (assign real crew to package event days) ───────────
model PackageCrewSlot {
  id                   Int      @id @default(autoincrement())
  package_id           Int
  package_event_day_id Int
  crew_id              Int? // Nullable: null = unassigned slot, set = real crew assigned
  job_role_id          Int // Required: which job role this slot requires
  hours                Decimal  @default(8) @db.Decimal(4, 1)
  label                String? // Optional display override: "Lead", "B-Cam", etc.
  order_index          Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  package              service_packages         @relation(fields: [package_id], references: [id], onDelete: Cascade)
  package_event_day    PackageEventDay          @relation(fields: [package_event_day_id], references: [id], onDelete: Cascade)
  crew                 Crew?                    @relation(fields: [crew_id], references: [id], onDelete: SetNull)
  job_role             job_roles                @relation(fields: [job_role_id], references: [id], onDelete: Restrict)
  equipment            PackageCrewSlotEquipment[]
  activity_assignments PackageCrewSlotActivity[]

  @@unique([package_id, package_event_day_id, job_role_id, order_index])
  @@index([package_id])
  @@index([package_event_day_id])
  @@index([crew_id])
  @@index([job_role_id])
  @@map("package_crew_slots")
}

// Equipment assigned to a crew slot for a specific package-day (overrides template defaults)
model PackageCrewSlotEquipment {
  id                   Int      @id @default(autoincrement())
  package_crew_slot_id Int
  equipment_id         Int
  is_primary           Boolean  @default(false)
  created_at           DateTime @default(now())

  package_crew_slot PackageCrewSlot @relation(fields: [package_crew_slot_id], references: [id], onDelete: Cascade)
  equipment         equipment       @relation(fields: [equipment_id], references: [id], onDelete: Cascade)

  @@unique([package_crew_slot_id, equipment_id])
  @@index([package_crew_slot_id])
  @@index([equipment_id])
  @@map("package_crew_slot_equipment")
}

// ─── Package Day Subjects ──────────────────────────────────────────
// Subjects (people/objects) assigned to a package's event day.
// Uses junction table PackageDaySubjectActivity for multi-activity assignment.
model PackageDaySubject {
  id                    Int             @id @default(autoincrement())
  package_id            Int
  event_day_template_id Int
  role_template_id      Int? // Link to SubjectRole (e.g., "Bride")
  name                  String // Display name ("Bride", "Groom", etc.)
  count                 Int?    // Optional headcount for groups (e.g. 6 Bridesmaids)
  notes                 String?
  order_index           Int      @default(0)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  package              service_packages           @relation(fields: [package_id], references: [id], onDelete: Cascade)
  event_day            EventDay                   @relation(fields: [event_day_template_id], references: [id], onDelete: Cascade)
  role_template        SubjectRole?               @relation(fields: [role_template_id], references: [id], onDelete: SetNull)
  activity_assignments PackageDaySubjectActivity[]

  @@unique([package_id, event_day_template_id, name])
  @@index([package_id])
  @@index([event_day_template_id])
  @@index([role_template_id])
  @@map("package_day_subjects")
}

// ─── Package Event Day Locations ───────────────────────────────────
// Locations assigned to a package's event day or activity.
// Mirrors PackageDaySubject pattern.
model PackageEventDayLocation {
  id                    Int      @id @default(autoincrement())
  package_id            Int
  event_day_template_id Int
  package_activity_id   Int? // Optional: assign to a specific activity
  location_id           Int // FK → LocationsLibrary
  notes                 String?
  order_index           Int      @default(0)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  package          service_packages @relation(fields: [package_id], references: [id], onDelete: Cascade)
  event_day        EventDay @relation(fields: [event_day_template_id], references: [id], onDelete: Cascade)
  package_activity PackageActivity? @relation(fields: [package_activity_id], references: [id], onDelete: SetNull)
  location         LocationsLibrary @relation(fields: [location_id], references: [id], onDelete: Cascade)

  @@unique([package_id, event_day_template_id, location_id])
  @@index([package_id])
  @@index([event_day_template_id])
  @@index([package_activity_id])
  @@index([location_id])
  @@map("package_event_day_locations")
}

// Proper join table: Package ↔ Film (replaces JSON contents.films approach)
model PackageFilm {
  id          Int      @id @default(autoincrement())
  package_id  Int
  film_id     Int
  order_index Int      @default(0)
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  package         service_packages           @relation(fields: [package_id], references: [id], onDelete: Cascade)
  film            Film                       @relation(fields: [film_id], references: [id], onDelete: Cascade)
  scene_schedules PackageFilmSceneSchedule[]
  project_films   ProjectFilm[]

  @@unique([package_id, film_id])
  @@index([package_id])
  @@index([film_id])
  @@map("package_films")
}

// Package-level scene schedule overrides
// Inherits from FilmSceneSchedule but allows package-specific customization
model PackageFilmSceneSchedule {
  id                         Int      @id @default(autoincrement())
  package_film_id            Int
  scene_id                   Int
  event_day_template_id      Int?
  package_activity_id        Int? // Which activity this scene belongs to
  scheduled_start_time       String? // Override film default
  scheduled_duration_minutes Int? // Override film default
  moment_schedules           Json? // Override film default
  beat_schedules             Json? // Override film default
  notes                      String?
  order_index                Int      @default(0)
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  package_film     PackageFilm       @relation(fields: [package_film_id], references: [id], onDelete: Cascade)
  scene            FilmScene         @relation(fields: [scene_id], references: [id], onDelete: Cascade)
  event_day        EventDay? @relation(fields: [event_day_template_id], references: [id], onDelete: SetNull)
  package_activity PackageActivity?  @relation(fields: [package_activity_id], references: [id], onDelete: SetNull)

  @@unique([package_film_id, scene_id])
  @@index([package_film_id])
  @@index([event_day_template_id])
  @@index([package_activity_id])
  @@map("package_film_scene_schedules")
}

// Project-level event days (actual dates mapped to templates)
// Dual-owner: owned by either a project OR an inquiry (exactly one must be set)
model ProjectEventDay {
  id                    Int      @id @default(autoincrement())
  project_id            Int? // Nullable: set when owned by project
  inquiry_id            Int? // Nullable: set when owned by inquiry (before booking)
  event_day_template_id Int?
  name                  String // "Wedding Day", or custom name
  date                  DateTime @db.Date
  start_time            String? // "08:00"
  end_time              String? // "23:00"
  order_index           Int      @default(0)
  notes                 String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  project            projects?                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  inquiry            inquiries?                 @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  event_day_template EventDay?          @relation(fields: [event_day_template_id], references: [id], onDelete: SetNull)
  scene_schedules    ProjectFilmSceneSchedule[]
  activities         ProjectActivity[]
  day_crew_slots    ProjectCrewSlot[]
  subjects           ProjectDaySubject[]
  location_slots     ProjectLocationSlot[]

  @@index([project_id])
  @@index([inquiry_id])
  @@index([event_day_template_id])
  @@map("project_event_days")
}

// Project-level activities (actual scheduled activities with real times)
// Dual-owner: owned by either a project OR an inquiry (exactly one must be set)
model ProjectActivity {
  id                   Int      @id @default(autoincrement())
  project_id           Int? // Nullable: set when owned by project
  inquiry_id           Int? // Nullable: set when owned by inquiry (before booking)
  project_event_day_id Int
  package_activity_id  Int? // Link back to package activity template
  name                 String // "Bridal Prep", "Ceremony", etc.
  description          String?
  color                String?
  icon                 String?
  start_time           String? // Actual "HH:MM"
  end_time             String? // Actual "HH:MM"
  duration_minutes     Int?
  order_index          Int      @default(0)
  notes                String?
  is_locked            Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  project           projects?                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  inquiry           inquiries?                 @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  project_event_day ProjectEventDay            @relation(fields: [project_event_day_id], references: [id], onDelete: Cascade)
  package_activity  PackageActivity?           @relation(fields: [package_activity_id], references: [id], onDelete: SetNull)
  scene_schedules   ProjectFilmSceneSchedule[]
  moments           ProjectActivityMoment[]
  crew_slot_assignments  ProjectCrewSlotActivity[]
  subject_assignments   ProjectDaySubjectActivity[]
  location_assignments  ProjectLocationActivityAssignment[]

  @@index([inquiry_id])
  @@index([project_event_day_id])
  @@index([package_activity_id])
  @@map("project_activities")
}

// Project-level film linkage (owns the film instance for this project/inquiry)
// Dual-owner: owned by either a project OR an inquiry (exactly one must be set)
model ProjectFilm {
  id              Int      @id @default(autoincrement())
  project_id      Int? // Nullable: set when owned by project
  inquiry_id      Int? // Nullable: set when owned by inquiry (before booking)
  film_id         Int
  package_film_id Int? // Which package-film this originated from
  order_index     Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  project         projects?                  @relation(fields: [project_id], references: [id], onDelete: Cascade)
  inquiry         inquiries?                 @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  film            Film                       @relation(fields: [film_id], references: [id], onDelete: Cascade)
  package_film    PackageFilm?               @relation(fields: [package_film_id], references: [id], onDelete: SetNull)
