// ─── Project-Level Package Snapshot Models ───────────────────────────
// These are independent clones of package data, owned by the project.
// Created once during inquiry → project conversion. Never sync back.

// Project activity moments (cloned from PackageActivityMoment)
// Dual-owner: owned by either a project OR an inquiry (exactly one must be set)
model ProjectActivityMoment {
  id                    Int      @id @default(autoincrement())
  project_id            Int? // Nullable: set when owned by project
  inquiry_id            Int? // Nullable: set when owned by inquiry (before booking)
  project_activity_id   Int
  source_package_moment_id Int? // Traceability to original PackageActivityMoment
  name                  String // "Processional", "Vows", "First Dance", etc.
  order_index           Int      @default(0)
  duration_seconds      Int      @default(60)
  is_required           Boolean  @default(true)
  notes                 String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  project          projects?        @relation(fields: [project_id], references: [id], onDelete: Cascade)
  inquiry          inquiries?       @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  project_activity ProjectActivity  @relation(fields: [project_activity_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@index([inquiry_id])
  @@index([project_activity_id])
  @@map("project_activity_moments")
}

// Project day subjects (cloned from PackageDaySubject)
// Adds real_name for actual person name at project level
// Dual-owner: owned by either a project OR an inquiry (exactly one must be set)
model ProjectDaySubject {
  id                        Int             @id @default(autoincrement())
  project_id                Int? // Nullable: set when owned by project
  inquiry_id                Int? // Nullable: set when owned by inquiry (before booking)
  project_event_day_id      Int
  source_package_subject_id Int? // Traceability to original PackageDaySubject
  role_template_id          Int? // Link to SubjectRole (e.g., "Bride")
  contact_id                Int? // FK → contacts when real_name resolves to a known contact
  name                      String // Role display name ("Bride", "Groom", etc.)
  real_name                 String? // Actual person name ("Sarah Johnson")
  count                     Int?    // Optional headcount for groups
  member_names              Json?   // Named slots for group members, e.g. ["Sarah", "Emily", "", ""] — length matches count
  notes                     String?
  order_index               Int             @default(0)
  created_at                DateTime        @default(now())
  updated_at                DateTime        @updatedAt

  project           projects?              @relation(fields: [project_id], references: [id], onDelete: Cascade)
  inquiry           inquiries?             @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  project_event_day ProjectEventDay        @relation(fields: [project_event_day_id], references: [id], onDelete: Cascade)
  role_template     SubjectRole?           @relation(fields: [role_template_id], references: [id], onDelete: SetNull)
  contact           contacts?              @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  activity_assignments ProjectDaySubjectActivity[]

  @@index([project_id])
  @@index([inquiry_id])
  @@index([project_event_day_id])
  @@index([role_template_id])
  @@index([contact_id])
  @@map("project_day_subjects")
}

// Project location slots (cloned from PackageLocationSlot)
// Adds name, address, and optional LocationsLibrary binding for real venue details
// Dual-owner: owned by either a project OR an inquiry (exactly one must be set)
model ProjectLocationSlot {
  id                                Int      @id @default(autoincrement())
  project_id                        Int? // Nullable: set when owned by project
  inquiry_id                        Int? // Nullable: set when owned by inquiry (before booking)
  project_event_day_id              Int
  source_package_location_slot_id   Int? // Traceability to original PackageLocationSlot
  location_number                   Int // Slot number (1-5)
  // Deprecated: name/address kept for migration; use location_id → LocationsLibrary instead
  name                              String? // @deprecated — migrate to location_id
  address                           String? // @deprecated — migrate to location_id
  location_id                       Int? // FK → LocationsLibrary (single source of truth for venue details)
  notes                             String? // Inquiry/project-specific notes for this venue use
  order_index                       Int      @default(0)
  created_at                        DateTime @default(now())
  updated_at                        DateTime @updatedAt

  project           projects?         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  inquiry           inquiries?        @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  project_event_day ProjectEventDay   @relation(fields: [project_event_day_id], references: [id], onDelete: Cascade)
  location          LocationsLibrary? @relation(fields: [location_id], references: [id], onDelete: SetNull)
  activity_assignments ProjectLocationActivityAssignment[]

  @@index([project_id])
  @@index([inquiry_id])
  @@index([project_event_day_id])
  @@index([location_id])
  @@map("project_location_slots")
}

// Project crew slots (cloned from PackageCrewSlot)
// Dual-owner: owned by either a project OR an inquiry (exactly one must be set)
model ProjectCrewSlot {
  id                   Int      @id @default(autoincrement())
  project_id           Int? // Nullable: set when owned by project
  inquiry_id           Int? // Nullable: set when owned by inquiry (before booking)
  project_event_day_id Int
  source_slot_id       Int? // Traceability to original PackageCrewSlot
  crew_id              Int? // Nullable: null = unassigned slot
  job_role_id          Int // Required: which job role this slot requires
  hours                Decimal  @default(8) @db.Decimal(4, 1)
  label                String? // Optional display override
  order_index          Int      @default(0)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  project              projects?         @relation(fields: [project_id], references: [id], onDelete: Cascade)
  inquiry              inquiries?        @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  project_event_day    ProjectEventDay   @relation(fields: [project_event_day_id], references: [id], onDelete: Cascade)
  crew                 Crew?             @relation(fields: [crew_id], references: [id], onDelete: SetNull)
  job_role             job_roles         @relation(fields: [job_role_id], references: [id], onDelete: Restrict)
  equipment            ProjectCrewSlotEquipment[]
  activity_assignments ProjectCrewSlotActivity[]

  @@index([project_id])
  @@index([inquiry_id])
  @@index([project_event_day_id])
  @@index([crew_id])
  @@index([job_role_id])
  @@map("project_crew_slots")
}

// Equipment assigned to a project crew slot
model ProjectCrewSlotEquipment {
  id                   Int      @id @default(autoincrement())
  project_crew_slot_id Int
  equipment_id         Int
  is_primary           Boolean  @default(false)
  created_at           DateTime @default(now())

  project_crew_slot ProjectCrewSlot @relation(fields: [project_crew_slot_id], references: [id], onDelete: Cascade)
  equipment         equipment       @relation(fields: [equipment_id], references: [id], onDelete: Cascade)

  @@unique([project_crew_slot_id, equipment_id])
  @@index([project_crew_slot_id])
  @@index([equipment_id])
  @@map("project_crew_slot_equipment")
}

