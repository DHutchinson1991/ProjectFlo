  name                 String   // "Trailer", "Highlights", "Same-Day Edit"
  min_duration_seconds Int      // Target minimum duration
  max_duration_seconds Int      // Target maximum duration
  is_system_seeded     Boolean  @default(false)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  brand brands? @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  films Film[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@map("montage_presets")
