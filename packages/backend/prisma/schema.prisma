// ─── Workflow Template Tasks ─────────────────────────────────────────
// Links task_library entries to workflow templates. A workflow template
// is a saved preset/selection of tasks from the task library.
// Phase comes from the task_library entry but can be overridden.

model workflow_template_tasks {
  id                     Int                @id @default(autoincrement())
  workflow_template_id   Int
  task_library_id        Int
  phase                  project_phase // Copied from task_library.phase, can be overridden
  override_hours         Decimal?           @db.Decimal(8, 2) // Override task_library.effort_hours
  override_assignee_role String? // Default role to assign
  order_index            Int                @default(0)
  is_required            Boolean            @default(true)
  is_active              Boolean            @default(true)
  created_at             DateTime           @default(now())
  updated_at             DateTime           @updatedAt
  workflow_template      workflow_templates @relation(fields: [workflow_template_id], references: [id], onDelete: Cascade)
  task_library           task_library       @relation(fields: [task_library_id], references: [id], onDelete: Cascade)

  @@unique([workflow_template_id, task_library_id])
  @@index([workflow_template_id])
  @@index([workflow_template_id, phase])
  @@map("workflow_template_tasks")
}

// ─── Skill-to-Role Mapping ─────────────────────────────────────────────
// Maps skill names (used in task_library.skills_needed[]) to job_roles
// and optionally to a specific payment_bracket tier.
// When payment_bracket_id is set, the skill is tier-specific: higher tiers
// accumulate more skills. Resolution picks the highest tier whose skills
// match the task's skills_needed[].

model skill_role_mappings {
  id                 Int               @id @default(autoincrement())
  skill_name         String            // e.g. "Video Editing", "Color Grading"
  job_role_id        Int
  payment_bracket_id Int?              // when set, skill is tier-specific
  brand_id           Int?
  priority           Int               @default(1) // higher = stronger match
  is_active          Boolean           @default(true)
  created_at         DateTime          @default(now())
  updated_at         DateTime          @updatedAt
  job_role           job_roles         @relation(fields: [job_role_id], references: [id], onDelete: Cascade)
  payment_bracket    payment_brackets? @relation(fields: [payment_bracket_id], references: [id], onDelete: Cascade)
  brand              brands?           @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@unique([skill_name, job_role_id, payment_bracket_id, brand_id])
  @@index([skill_name])
  @@index([job_role_id])
  @@index([payment_bracket_id])
  @@index([brand_id])
  @@map("skill_role_mappings")
}

model task_library {
  id                       Int                        @id @default(autoincrement())
  name                     String
  description              String?
  workflow_description     String?                    // Fuller workflow narrative (auto-populated from subtask descriptions, independently editable)
  phase                    project_phase
  effort_hours             Decimal?                   @db.Decimal(8, 2)
  recorded_hours           Decimal?                   @db.Decimal(8, 2)
  skills_needed            String[]
  pricing_type             pricing_type_options       @default(Hourly)
  fixed_price              Decimal?                   @db.Decimal(10, 2)
  hourly_rate              Decimal?                   @db.Decimal(8, 2)
  complexity_score         Int?                       @default(1)
  default_job_role_id      Int?
  notes                    String?
  order_index              Int                        @default(0)
  brand_id                 Int
  is_active                Boolean                    @default(true)
  trigger_type             task_trigger_type          @default(always)
  due_date_offset_days      Int?                       // Days from the reference date to set due_date
  due_date_offset_reference due_date_offset_reference? // Which date the offset is measured from
  parent_task_id           Int?                       // Self-reference for parent/child (task group → children)
  is_task_group            Boolean                    @default(false) // True = task group container (collapsible section within a phase)
  is_auto_only             Boolean                    @default(false) // True = auto-completes only, cannot be manually toggled
  is_on_site               Boolean                    @default(false) // True = on-site work (billed at day rate); false = off-site (billed hourly)
  default_crew_id   Int?                       // Auto-resolved when exactly 1 crew record has the role
  created_at               DateTime                   @default(now())
  updated_at               DateTime                   @updatedAt
  brand                    brands                     @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  default_job_role         job_roles?                 @relation("TaskLibraryDefaultRole", fields: [default_job_role_id], references: [id], onDelete: SetNull)
  default_crew      Crew?               @relation("TaskLibraryDefaultCrew", fields: [default_crew_id], references: [id], onDelete: SetNull)
  parent_task              task_library?              @relation("TaskLibraryParentChild", fields: [parent_task_id], references: [id], onDelete: SetNull)
  children                 task_library[]             @relation("TaskLibraryParentChild")
  task_library_benchmarks           task_library_benchmarks[]
  task_library_skill_rates          task_library_skill_rates[]
  task_library_subtask_templates    task_library_subtask_templates[]
  workflow_template_tasks           workflow_template_tasks[]
  project_tasks                     project_tasks[]
  inquiry_tasks                     inquiry_tasks[]
  crew_payment_rules                crew_payment_rules[]

  @@index([brand_id])
  @@index([phase])
  @@index([is_active])
  @@index([phase, order_index])
  @@index([default_job_role_id])
  @@index([default_crew_id])
  @@index([parent_task_id])
  @@map("task_library")
}

model task_library_benchmarks {
  id                        Int          @id @default(autoincrement())
  task_library_id           Int
  crew_id            Int
  crew_default_hours Decimal?     @db.Decimal(8, 2)
  crew_average_hours Decimal?     @db.Decimal(8, 2)
  crew_best_hours    Decimal?     @db.Decimal(8, 2)
  completed_count           Int          @default(0)
  created_at                DateTime     @default(now())
  updated_at                DateTime     @updatedAt
  crew               Crew @relation(fields: [crew_id], references: [id], onDelete: Cascade)
  task_library              task_library @relation(fields: [task_library_id], references: [id], onDelete: Cascade)

  @@unique([task_library_id, crew_id])
  @@map("task_library_benchmarks")
}

model task_library_skill_rates {
  id              Int          @id @default(autoincrement())
  task_library_id Int
  skill_name      String
  skill_level     String
  hourly_rate     Decimal      @db.Decimal(8, 2)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  task_library    task_library @relation(fields: [task_library_id], references: [id], onDelete: Cascade)

  @@unique([task_library_id, skill_name, skill_level])
  @@map("task_library_skill_rates")
}

// ─── Task Library Subtask Templates ────────────────────────────────────
// Defines subtask templates for task_library entries.
// When inquiry_tasks are generated, subtasks are created from these templates
// using task_library_id (not task name) for reliable mapping.

model task_library_subtask_templates {
  id              Int          @id @default(autoincrement())
  task_library_id Int
  subtask_key     String       // Unique key within the task (e.g. "verify_submission_data")
  name            String       // Display name (e.g. "Verify Submission Data")
  description     String?      // Fuller description of what this step does / automation behaviour
  order_index     Int          @default(0)
  is_auto_only    Boolean      @default(false) // True = system-managed, cannot be manually toggled
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  task_library    task_library @relation(fields: [task_library_id], references: [id], onDelete: Cascade)

  @@unique([task_library_id, subtask_key])
  @@index([task_library_id, order_index])
  @@map("task_library_subtask_templates")
}

// ─── Project Tasks (auto-generated from task library) ─────────────────
// Created when task auto-generation runs for a project+package.
// Separate from legacy `tasks` table.

model project_tasks {
  id                    Int                  @id @default(autoincrement())
  project_id            Int
  task_library_id       Int? // Source task from library (nullable for manual additions)
  package_id            Int? // Which package triggered this generation
  name                  String
  description           String?
  phase                 project_phase
  trigger_type          task_trigger_type    @default(always)
  trigger_context       String? // e.g. "Film: Highlight Film", "Event Day: Day 1"
  estimated_hours       Decimal?             @db.Decimal(8, 2)
  actual_hours          Decimal?             @db.Decimal(8, 2)
  status                tasks_status         @default(To_Do)
  due_date              DateTime?
  assigned_to_id        Int?
  pricing_type          pricing_type_options @default(Hourly)
  fixed_price           Decimal?             @db.Decimal(10, 2)
  hourly_rate           Decimal?             @db.Decimal(8, 2)
  order_index           Int                  @default(0)
  is_active             Boolean              @default(true)
  // Skill-to-Role auto-resolution fields
  resolved_job_role_id  Int?                 // Auto-resolved from skill_role_mappings
  resolved_bracket_id   Int?                 // Auto-resolved bracket based on complexity_score
  resolved_rate         Decimal?             @db.Decimal(8, 2) // Rate snapshot from bracket at generation time
  resolved_skill        String?              // Which skill triggered the resolution
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt

  project            projects          @relation(fields: [project_id], references: [id], onDelete: Cascade)
  task_library       task_library?     @relation(fields: [task_library_id], references: [id], onDelete: SetNull)
  package            service_packages? @relation(fields: [package_id], references: [id], onDelete: SetNull)
  assigned_to        Crew?     @relation("AssignedProjectTasks", fields: [assigned_to_id], references: [id], onDelete: SetNull)
  resolved_job_role  job_roles?        @relation("ResolvedJobRole", fields: [resolved_job_role_id], references: [id], onDelete: SetNull)
  resolved_bracket   payment_brackets? @relation("ResolvedBracket", fields: [resolved_bracket_id], references: [id], onDelete: SetNull)

  @@index([project_id])
  @@index([task_library_id])
  @@index([package_id])
  @@index([assigned_to_id])
  @@index([resolved_job_role_id])
  @@index([resolved_bracket_id])
  @@index([phase])
  @@index([status])
  @@map("project_tasks")
}

// ─── Inquiry Tasks (auto-generated from task library for pre-booking) ─
// Created when an inquiry is received/created.
// Tracks per-task completion through the Inquiry → Booking pipeline.

model inquiry_tasks {
  id                      Int               @id @default(autoincrement())
  inquiry_id              Int
  task_library_id         Int?              // Source task from library (nullable for manual additions)
  parent_inquiry_task_id  Int?              // Self-reference: child task → parent stage task
  name                    String
  description             String?
  phase                   project_phase
  trigger_type            task_trigger_type @default(always)
  estimated_hours         Decimal?          @db.Decimal(8, 2)
  due_date                DateTime?
  status                  tasks_status      @default(To_Do)
  order_index             Int               @default(0)
  completed_at            DateTime?
  completed_by_id         Int?
  assigned_to_id          Int?              // Crew assigned to work on this task
  job_role_id             Int?              // Role needed for this task (from task_library.default_job_role_id)
  is_active               Boolean           @default(true)
  is_task_group           Boolean           @default(false) // True = this is a task group container row
  created_at              DateTime          @default(now())
  updated_at              DateTime          @updatedAt

  inquiry             inquiries      @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)
  task_library        task_library?  @relation(fields: [task_library_id], references: [id], onDelete: SetNull)
  completed_by        Crew?  @relation("CompletedInquiryTasks", fields: [completed_by_id], references: [id], onDelete: SetNull)
  assigned_to         Crew?  @relation("AssignedInquiryTasks", fields: [assigned_to_id], references: [id], onDelete: SetNull)
  job_role            job_roles?     @relation("InquiryTaskJobRole", fields: [job_role_id], references: [id], onDelete: SetNull)
  parent_inquiry_task inquiry_tasks? @relation("InquiryTaskParentChild", fields: [parent_inquiry_task_id], references: [id], onDelete: Cascade)
  children            inquiry_tasks[]         @relation("InquiryTaskParentChild")
  subtasks            inquiry_task_subtasks[]
  events              inquiry_task_events[]

  @@index([inquiry_id])
  @@index([task_library_id])
  @@index([inquiry_id, order_index])
  @@index([status])
  @@index([parent_inquiry_task_id])
  @@index([assigned_to_id])
  @@index([job_role_id])
  @@map("inquiry_tasks")
}

model inquiry_task_subtasks {
  id               Int          @id @default(autoincrement())
  inquiry_task_id  Int
  subtask_key      String
  name             String
  status           tasks_status @default(To_Do)
  order_index      Int          @default(0)
  is_auto_only     Boolean      @default(false)
  completed_at     DateTime?
  completed_by_id  Int?
  job_role_id      Int?
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  inquiry_task inquiry_tasks @relation(fields: [inquiry_task_id], references: [id], onDelete: Cascade)
  completed_by Crew? @relation("CompletedInquiryTaskSubtasks", fields: [completed_by_id], references: [id], onDelete: SetNull)
  job_role     job_roles?    @relation("InquiryTaskSubtaskJobRole", fields: [job_role_id], references: [id], onDelete: SetNull)

  @@unique([inquiry_task_id, subtask_key])
  @@index([inquiry_task_id, order_index])
  @@index([status])
  @@index([completed_by_id])
  @@index([job_role_id])
  @@map("inquiry_task_subtasks")
}

model inquiry_task_events {
  id           Int      @id @default(autoincrement())
  task_id      Int
  event_type   String
  triggered_by String?
  description  String
  occurred_at  DateTime @default(now())
  inquiry_task inquiry_tasks @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id])
  @@map("inquiry_task_events")
}

