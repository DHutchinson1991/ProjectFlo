  order_index                Int
  notes                      String?   // Creative direction hints
  created_at                 DateTime  @default(now())
  updated_at                 DateTime  @updatedAt

  template FilmStructureTemplate @relation(fields: [film_structure_template_id], references: [id], onDelete: Cascade)

