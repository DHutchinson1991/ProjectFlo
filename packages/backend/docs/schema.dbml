Table estimate_payment_milestones {
  id Int [pk, increment]
  estimate_id Int [not null]
  label String [not null]
  amount Decimal [not null]
  due_date DateTime [not null]
  status String [not null, default: 'PENDING']
  notes String
  order_index Int [not null, default: 0]
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  estimate estimates [not null]
}

Table contract_clause_categories {
  id Int [pk, increment]
  brand_id Int [not null]
  name String [not null]
  description String
  order_index Int [not null, default: 0]
  is_default Boolean [not null, default: false]
  country_code String
  is_active Boolean [not null, default: true]
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  brand brands [not null]
  clauses contract_clauses [not null]
}

Table contract_clauses {
  id Int [pk, increment]
  category_id Int [not null]
  brand_id Int [not null]
  title String [not null]
  body String [not null]
  clause_type String [not null, default: 'STANDARD']
  country_code String
  is_default Boolean [not null, default: false]
  is_active Boolean [not null, default: true]
  order_index Int [not null, default: 0]
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  category contract_clause_categories [not null]
  brand brands [not null]
  template_clauses contract_template_clauses [not null]
}

Table contract_templates {
  id Int [pk, increment]
  brand_id Int [not null]
  name String [not null]
  description String
  payment_schedule_template_id Int
  is_default Boolean [not null, default: false]
  is_active Boolean [not null, default: true]
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  brand brands [not null]
  payment_schedule payment_schedule_templates
  template_clauses contract_template_clauses [not null]
}

Table contract_template_clauses {
  id Int [pk, increment]
  template_id Int [not null]
  clause_id Int [not null]
  order_index Int [not null, default: 0]
  override_body String
  created_at DateTime [default: `now()`, not null]
  template contract_templates [not null]
  clause contract_clauses [not null]

  indexes {
    (template_id, clause_id) [unique]
  }
}

Table package_requests {
  id Int [pk, increment]
  inquiry_id Int [not null]
  selected_package_id Int
  customisations Json
  notes String
  status String [not null, default: 'pending']
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  inquiry inquiries [not null]
}

Table inquiry_equipment_reservations {
  id Int [pk, increment]
  inquiry_id Int [not null]
  equipment_id Int [not null]
  project_crew_slot_equipment_id Int [not null]
  equipment_availability_id Int
  status inquiry_equipment_reservation_status [not null, default: 'reserved']
  reserved_at DateTime [default: `now()`, not null]
  cancelled_at DateTime
  created_at DateTime [default: `now()`, not null]
  inquiry inquiries [not null]
  equipment equipment [not null]

  indexes {
    (inquiry_id, project_crew_slot_equipment_id) [unique]
  }
}

Table inquiry_crew_availability_requests {
  id Int [pk, increment]
  inquiry_id Int [not null]
  crew_id Int [not null]
  project_crew_slot_id Int
  status inquiry_crew_availability_request_status [not null, default: 'pending']
  sent_at DateTime [default: `now()`, not null]
  cancelled_at DateTime
  created_at DateTime [default: `now()`, not null]
  updated_at DateTime [not null]
  inquiry inquiries [not null]
  crew crew [not null]
  slot project_crew_slots

  indexes {
    (inquiry_id, crew_id) [unique]
  }
}

