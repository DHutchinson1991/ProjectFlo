{
  "name": "projectflo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "format": "prettier --write \"packages/**/*.{js,ts,jsx,tsx,json}\"",
    "lint": "eslint \"packages/**/*.{js,ts,jsx,tsx}\"",
    "lint:fix": "eslint \"packages/**/*.{js,ts,jsx,tsx}\" --fix",
    "dev": "concurrently \"pnpm --filter backend run start:dev\" \"pnpm --filter frontend run dev\"",
    "auth": "node Scripts/auth-token/get-auth-token.js",
    "auth:dev": "node Scripts/auth-token/get-auth-token.js --env development",
    "auth:staging": "node Scripts/auth-token/get-auth-token.js --env staging",
    "auth:prod": "node Scripts/auth-token/get-auth-token.js --env production",
    "auth:extend": "node Scripts/auth-token/get-auth-token.js --extend",
    "auth:force": "node Scripts/auth-token/get-auth-token.js --force",
    "auth:interactive": "node Scripts/auth-token/get-auth-token.js --interactive",
    "auth:help": "node Scripts/auth-token/get-auth-token.js --help",
    "auth:dev-token": "node Scripts/auth-token/get-dev-token.js",
    "auth:dev-token:staging": "node Scripts/auth-token/get-dev-token.js --env staging",
    "auth:dev-token:prod": "node Scripts/auth-token/get-dev-token.js --env production",
    "auth:dev-token:force": "node Scripts/auth-token/get-dev-token.js --force",
    "auth:dev-token:help": "node Scripts/auth-token/get-dev-token.js --help",
    "auth:setup": "node get-auth-token.js --interactive",
    "auth:quick": "node get-auth-token.js --extend --force",
    "auth:check": "node get-auth-token.js --verbose",
    "dev:auth": "npm run auth:dev && npm run dev",
    "dev:staging": "npm run auth:staging && concurrently \"pnpm --filter backend run start:staging\" \"pnpm --filter frontend run dev\"",
    "dev:prod": "npm run auth:prod && concurrently \"pnpm --filter backend run start:prod\" \"pnpm --filter frontend run build && pnpm --filter frontend run start\"",
    "test:auth": "npm run auth:dev && npm run test",
    "test:api": "npm run auth:dev && node scripts/test-api.js",
    "deploy:staging": "npm run auth:staging && npm run build && npm run deploy:staging:only",
    "deploy:prod": "npm run auth:prod && npm run build && npm run deploy:prod:only"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "concurrently": "^9.1.2",
    "dotenv": "^17.2.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "node-fetch": "^2.7.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.34.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "react-leaflet": "4"
  }
}