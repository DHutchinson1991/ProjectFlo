{
  "name": "projectflo",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend run start:dev\" \"pnpm --filter frontend run dev\"",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "format": "prettier --write \"packages/**/*.{js,ts,jsx,tsx,json}\"",
    "lint": "eslint \"packages/**/*.{js,ts,jsx,tsx}\"",
    "lint:fix": "eslint \"packages/**/*.{js,ts,jsx,tsx}\" --fix",
    "typecheck": "pnpm -r typecheck",
    "typecheck:frontend": "pnpm --filter frontend typecheck",
    "typecheck:backend": "pnpm --filter backend typecheck",
    "check": "pnpm typecheck && pnpm lint",
    "check:frontend": "pnpm typecheck:frontend && pnpm --filter frontend lint",
    "check:backend": "pnpm typecheck:backend && pnpm --filter backend lint",
    "db:generate": "pnpm --filter backend exec prisma generate",
    "db:push": "pnpm --filter backend exec prisma db push",
    "db:seed": "pnpm --filter backend exec prisma db seed",
    "db:migrate": "pnpm --filter backend exec prisma migrate dev",
    "db:studio": "pnpm --filter backend exec prisma studio",
    "db:reset": "pnpm --filter backend exec prisma db push --force-reset && pnpm db:seed",
    "auth": "node tools/auth/get-token.js",
    "auth:dev": "node tools/auth/get-token.js --env development",
    "auth:staging": "node tools/auth/get-token.js --env staging",
    "auth:prod": "node tools/auth/get-token.js --env production",
    "auth:extend": "node tools/auth/get-token.js --extend",
    "auth:force": "node tools/auth/get-token.js --force",
    "auth:refresh": "node tools/auth/get-token.js --extend --force",
    "auth:interactive": "node tools/auth/get-token.js --interactive",
    "auth:frontend": "node tools/auth/get-token.js --frontend",
    "auth:frontend:staging": "node tools/auth/get-token.js --frontend --env staging",
    "auth:frontend:force": "node tools/auth/get-token.js --frontend --force",
    "auth:help": "node tools/auth/get-token.js --help"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "concurrently": "^9.1.2",
    "dotenv": "^17.2.2",
    "eslint": "^9",
    "eslint-config-next": "15.3.3",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.2.0",
    "jest": "^29.7.0",
    "node-fetch": "^2.7.0",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.34.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt"
    ]
  }
}